# =========================================================================
# Vendor companion source — staged transiently into companions/<name> by
# CI before the openagentic-ui image builds its docs manifests. The
# companion source MUST NEVER be committed to this downstream repo —
# and the JSON docs manifests derived from them.
#
# The empty companions/ directory is kept with a .gitkeep placeholder
# so the Dockerfile's `COPY companions /companions` always has a source.
# =========================================================================
companions/*
!companions/.gitkeep

# superpowers:brainstorming session artifacts
.superpowers/

# Setup wizard deps (installed on first run by install.sh)
