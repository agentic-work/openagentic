{
  "name": "@openagentic/openagentic-exec",
  "version": "0.7.1",
  "description": "Isolated execution daemon for openagentic CLI and code-server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test:seed": "ts-node src/tests/seed.test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:entrypoint": "bash __tests__/entrypoint.test.sh"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.2",
    "vitest": "^4.1.5"
  }
}
