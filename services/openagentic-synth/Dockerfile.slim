# OAT Executor - Slim Build with cloud CLIs
#
# Runtime needs (per user directive 2026-04-08): aws, az, gcloud, uv, pip, python.
# These let synthesised code shell out to cloud CLIs when the Python SDKs don't
# cover a given operation. We keep the non-root `oat` user and a normal Debian
# shell layout (shells are REQUIRED — the az/gcloud/aws installers are bash
# scripts and the CLIs themselves exec bash subprocesses at runtime).

# =============================================================================
# Stage 1: Build Python deps into a venv
# =============================================================================
FROM python:3.11-slim-bookworm as builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY services/openagentic-synth/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# =============================================================================
# Stage 2: Production image
# =============================================================================
FROM python:3.11-slim-bookworm

# Base apt deps + Microsoft + GCP repo prerequisites
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      gnupg \
      lsb-release \
      unzip \
      apt-transport-https \
      jq \
      git \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# AWS CLI v2 (official bundled installer — architecture-aware)
# -----------------------------------------------------------------------------
RUN ARCH=$(dpkg --print-architecture) && \
    case "$ARCH" in \
      amd64) AWS_ARCH="x86_64" ;; \
      arm64) AWS_ARCH="aarch64" ;; \
      *) echo "unsupported arch: $ARCH" && exit 1 ;; \
    esac && \
    curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-${AWS_ARCH}.zip" -o /tmp/awscliv2.zip && \
    unzip -q /tmp/awscliv2.zip -d /tmp && \
    /tmp/aws/install --bin-dir /usr/local/bin --install-dir /usr/local/aws-cli && \
    rm -rf /tmp/awscliv2.zip /tmp/aws && \
    aws --version

# -----------------------------------------------------------------------------
# Azure CLI (official Microsoft apt repo)
# -----------------------------------------------------------------------------
RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | \
      gpg --dearmor -o /etc/apt/keyrings/microsoft.gpg && \
    chmod go+r /etc/apt/keyrings/microsoft.gpg && \
    AZ_REPO=$(lsb_release -cs) && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/azure-cli/ ${AZ_REPO} main" \
      > /etc/apt/sources.list.d/azure-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends azure-cli && \
    rm -rf /var/lib/apt/lists/* && \
    az version

# -----------------------------------------------------------------------------
# Google Cloud SDK (official Google apt repo)
# -----------------------------------------------------------------------------
RUN curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | \
      gpg --dearmor -o /etc/apt/keyrings/cloud.google.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
      > /etc/apt/sources.list.d/google-cloud-sdk.list && \
    apt-get update && apt-get install -y --no-install-recommends google-cloud-cli && \
    rm -rf /var/lib/apt/lists/* && \
    gcloud version

# -----------------------------------------------------------------------------
# uv — fast Python package manager (system-wide install)
# -----------------------------------------------------------------------------
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh && \
    uv --version

# Create non-root runtime user. Keep /bin/bash as login shell because the
# cloud CLIs spawn bash subprocesses at runtime (gcloud components, az extensions).
RUN groupadd -r oat -g 65532 && \
    useradd -r -g oat -u 65532 -d /app -s /bin/bash oat

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv

# Set environment
ENV PATH="/opt/venv/bin:/usr/local/aws-cli/v2/current/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# --- CLI state dirs (NOT credential storage) ---
# This container NEVER stores credentials at rest. Per-request auth is injected
# as environment variables by the API caller (AZURE_*/AWS_ACCESS_KEY_ID/
# GOOGLE_APPLICATION_CREDENTIALS/etc.) and dies with the Python process.
#
# The two vars below exist only because `az` and `gcloud` CLIs crash at startup
# if they can't create a writable config directory for transient state
# (telemetry, last-used region, logs — NO secrets). /app is mounted read-only
# in-cluster, and /tmp is a writable tmpfs that's wiped on pod restart, so we
# redirect the CLI state dirs there. AWS CLI doesn't need any equivalent — it
# reads env vars directly and never touches the filesystem unless you explicitly
# call `aws configure`, which we never do.
ENV AZURE_CONFIG_DIR=/tmp/.azure
ENV CLOUDSDK_CONFIG=/tmp/.config/gcloud

# OAT Executor configuration
ENV OAT_EXECUTOR_PORT=8090
ENV OAT_MAX_EXECUTION_TIME=30
ENV OAT_MAX_MEMORY_MB=256
ENV OAT_LOG_LEVEL=INFO

# OTEL configuration
ENV OTEL_SERVICE_NAME=openagentic-synth
ENV OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
ENV OTEL_PYTHON_LOG_CORRELATION=true

# Copy application code
WORKDIR /app
COPY --chown=oat:oat services/openagentic-synth/src/ /app/

# Create temp directory
RUN mkdir -p /tmp && chown oat:oat /tmp

# Run as non-root user
USER oat

# Health check endpoint
EXPOSE 8090

# Direct Python execution
ENTRYPOINT ["python", "-m", "openagentic_synth"]
