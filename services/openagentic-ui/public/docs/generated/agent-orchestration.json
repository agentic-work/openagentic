    {
      "id": "orchestration-patterns",
      "title": "Orchestration Patterns",
      "description": "Multi-agent execution patterns supported by the AgentOrchestrator.",
      "adminOnly": false,
      "items": [
        {
          "id": "orch-parallel",
          "name": "parallel",
          "description": "All agents run concurrently, results aggregated after all complete",
          "type": "orchestration-pattern"
        },
        {
          "id": "orch-sequential",
          "name": "sequential",
          "description": "Agents run one after another, each receiving prior results",
          "type": "orchestration-pattern"
        },
        {
          "id": "orch-supervisor",
          "name": "supervisor",
          "description": "A supervisor agent dynamically selects and delegates to worker agents",
          "type": "orchestration-pattern"
        },
        {
          "id": "orch-hierarchical",
          "name": "hierarchical",
          "description": "Multi-level agent tree with planning, execution, and validation layers",
          "type": "orchestration-pattern"
        }
      ]
    },
    {
      "id": "aggregation-strategies",
      "title": "Aggregation Strategies",
      "description": "How multi-agent results are combined into a final output.",
      "adminOnly": false,
      "items": [
        {
          "id": "agg-merge",
          "name": "merge",
          "description": "Concatenate all agent outputs into a single response",
          "type": "aggregation-strategy"
        },
        {
          "id": "agg-synthesize",
          "name": "synthesize",
          "description": "Use an LLM to synthesize a unified response from all outputs",
          "type": "aggregation-strategy"
        },
        {
          "id": "agg-first",
          "name": "first",
          "description": "Return the first successful agent result",
          "type": "aggregation-strategy"
        },
        {
          "id": "agg-vote",
          "name": "vote",
          "description": "Use consensus voting across agent outputs",
          "type": "aggregation-strategy"
        }
      ]
    },
