server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Allow larger file uploads (images, etc.)
    client_max_body_size 100M;

    # DNS resolver for dynamic upstream resolution
    # This allows nginx to resolve hostnames at runtime instead of startup
    # DNS_RESOLVER is set dynamically from /etc/resolv.conf at container startup
    # In Docker: 127.0.0.11, in K8s: cluster DNS (e.g., 10.43.0.10)
    resolver ${DNS_RESOLVER} valid=30s ipv6=off;

    # ===========================================
    # AUTHENTICATION SUBREQUEST ENDPOINT
    # ===========================================
    # Used by auth_request to validate user session before allowing access
    # to protected resources
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location = /internal/auth/verify {
        internal;
        set $api_auth_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_auth_upstream/api/auth/verify;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URI $request_uri;
        proxy_set_header X-Original-Method $request_method;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # ===========================================
    # API V1 ROUTES - OpenAgentic API Backend
    # ===========================================
    # These specific routes go to our API backend

    # MCP routes - unified MCP management
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location ^~ /api/v1/mcp/ {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # Models routes - available LLM models
    location ^~ /api/v1/models {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # OpenAI-compatible completions - used by AI Flow Builder (stateless, no chat sessions)
    location ^~ /api/v1/chat/completions {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
        # SSE streaming support
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300s;
        chunked_transfer_encoding on;
    }

    # API v1 status endpoint
    location = /api/v1/status {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # Credential Exchange routes - OAT/Synth token exchange
    location ^~ /api/v1/credentials/ {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # GitHub OAuth routes
    location ^~ /api/v1/github/ {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # Vector search routes
    location ^~ /api/v1/vector/ {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # User analytics routes (personal tool usage, etc.)
    location ^~ /api/v1/me/ {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # Webhook trigger routes
    location ^~ /api/v1/hooks/ {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }

    # Milvus API routes (for Attu embedded in Admin Portal)
    # Attu makes requests to /api/v1/milvus/* which need to be proxied to Attu backend
    # NOTE: Using variable for proxy_pass to allow runtime DNS resolution (Attu may not be deployed)
    location ^~ /api/v1/milvus/ {
        set $attu_upstream "http://${ATTU_HOST}:${ATTU_PORT}";
        proxy_pass $attu_upstream/api/v1/milvus/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
    }

    # Agent Proxy - agent orchestration service
    # Routes /api/agents/* to the openagentic-proxy service (separate container)
    location ^~ /api/agents/ {
        set $openagentic_proxy_upstream "http://${OPENAGENTIC_PROXY_HOST}:${OPENAGENTIC_PROXY_PORT}";
        proxy_pass $openagentic_proxy_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-API-Key $http_x_api_key;
        proxy_set_header Cookie $http_cookie;

        # SSE streaming support for agent execution events
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        chunked_transfer_encoding on;
        proxy_set_header X-Accel-Buffering "no";
    }

    # Proxy all API requests to backend
    # CRITICAL: ^~ prevents regex locations (like static file caching) from
    # intercepting /api/ URLs (e.g., /api/images/xxx.png was caught by the
    # ~* \.(png|jpg|...)$ location and returned nginx 404 instead of proxying)
    location ^~ /api/ {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-User-ID $http_x_user_id;
        # Frontend security header - injected by nginx proxy
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";

        # CRITICAL: SSE streaming support - disable ALL buffering
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        # Tell upstream proxies not to buffer
        proxy_set_header X-Accel-Buffering "no";
        # Ensure chunked encoding works
        chunked_transfer_encoding on;
        # Disable gzip for SSE (breaks chunked streaming)
        gzip off;
    }

    # ===========================================
    # AWCODE PTY WEBSOCKET TERMINAL
    # ===========================================
    # Proxies through API (Fastify WS proxy) which:
    #   1. Validates user JWT token
    #   2. Checks AWCode permission
    #   3. Translates session ID to slice ID
    #   4. Injects internal API key for code-manager auth
    # Direct terminal WebSocket — browser → exec service.
    # In single-user docker compose, exec is reachable as just "exec:3060".
    location ~ ^/ws/pod/([^/]+)/terminal/(.+)$ {
        set $sess_id $2;
        set $exec_ws_upstream "http://${EXEC_HOST}:${EXEC_PORT}";
        proxy_pass $exec_ws_upstream/ws/terminal/$sess_id$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # Legacy API-proxied terminal WebSocket (backward compat)
    location /api/code/ws/terminal {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # AWCode structured events WebSocket (V2 inline UI)
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location /api/code/ws/events {
        # CRITICAL: $is_args$args forwards query params (userId, token, sessionId)
        # Without this, user auth tokens are stripped and CLI falls back to Ollama mode
        set $awcode_events_upstream "http://${EXEC_HOST}:${EXEC_PORT}";
        proxy_pass $awcode_events_upstream/ws/events$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # /api/code/sessions is served by the API (mints the session token, calls the
    # exec client), NOT the exec directly — it falls through to `location ^~ /api/`.
    # (The legacy direct-to-exec sessions proxy was removed for the Claude Code rebuild.)

    # ===========================================
    # CODE-SERVER - VS Code Web IDE
    # ===========================================
    # Two modes of operation:
    # 1. Port-based routing (exec-container mode): /code-server/{port}/
    #    - Proxies to openagentic-manager container on the specified port
    # 2. Session-based routing (kubernetes mode): /code-server/session/{sessionId}/
    #    - Proxies to openagentic-manager which forwards to the correct runner pod

    # K8s mode: Session-based routing (must come before port-based)
    location ~ ^/code-server/session/([^/]+)/(.*)$ {
        # $1 = session ID, $2 = remaining path
        set $awcode_session_upstream "http://${EXEC_HOST}:${EXEC_PORT}";
        proxy_pass $awcode_session_upstream/code-server/session/$1/$2$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Accept-Encoding gzip;
        # Strip Origin header - code-server CSRF rejects external origins (403 on WebSocket)
        proxy_set_header Origin "";

        # WebSocket support for VS Code
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;

        # Disable buffering for real-time updates
        proxy_buffering off;
    }

    # K8s mode: Session-based routing without trailing content
    location ~ ^/code-server/session/([^/]+)/?$ {
        set $awcode_session_upstream "http://${EXEC_HOST}:${EXEC_PORT}";
        proxy_pass $awcode_session_upstream/code-server/session/$1/$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Accept-Encoding gzip;
        # Strip Origin header - code-server CSRF rejects external origins (403 on WebSocket)
        proxy_set_header Origin "";
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_buffering off;
    }

    # Exec-container mode: Port-based routing
    # URL format: /code-server/{port}/?folder=...
    # Proxies to openagentic-manager container on the specified port
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location ~ ^/code-server/(\d+)/(.*)$ {
        # $1 = port number, $2 = remaining path
        set $code_server_upstream "http://${CODE_SERVER_HOST}:$1";
        proxy_pass $code_server_upstream/$2$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Accept-Encoding gzip;
        # Strip Origin header - code-server CSRF rejects external origins (403 on WebSocket)
        proxy_set_header Origin "";

        # WebSocket support for VS Code
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;

        # Disable buffering for real-time updates
        proxy_buffering off;
    }

    # Exec-container mode: Port-based routing without trailing content
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location ~ ^/code-server/(\d+)/?$ {
        set $code_server_upstream "http://${CODE_SERVER_HOST}:$1";
        proxy_pass $code_server_upstream/$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Accept-Encoding gzip;
        # Strip Origin header - code-server CSRF rejects external origins (403 on WebSocket)
        proxy_set_header Origin "";
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_buffering off;
    }

    # DEDICATED SSE endpoint for chat streaming - maximum compatibility
    location /api/chat/stream {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-User-ID $http_x_user_id;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
        proxy_set_header Connection '';

        # CRITICAL SSE settings
        proxy_buffering off;
        proxy_cache off;
        proxy_set_header X-Accel-Buffering "no";
        chunked_transfer_encoding on;
        gzip off;

        # Long timeout for streaming
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;

        # SSE specific headers
        add_header Cache-Control 'no-cache, no-store, must-revalidate';
        add_header X-Accel-Buffering 'no';
    }
    
    # Remove conflicting proxy routes - these should be handled by React Router
    
    # UI doesn't need to expose metrics - Prometheus should scrape API directly
    location /metrics {
        return 404;
    }
    
    # UI health check endpoints
    location /ui-health {
        access_log off;
        return 200 "UI healthy\n";
        add_header Content-Type text/plain;
    }
    location /healthz {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }
    
    location /health {
        set $api_upstream "http://${API_HOST}:${API_PORT}";
        proxy_pass $api_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-OpenAgentic-Frontend "${FRONTEND_SECRET}";
    }
    
    # Handle auth callback routing - serve frontend, let React Router handle it
    location /auth/callback {
        try_files $uri $uri/ /index.html;
    }
    
    # Local auth requests now use /api/auth/local/* path directly via ingress
    # No special proxy needed since ingress routes /api/* to API service
    
    # Proxy MCP Inspector requests - both paths
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location /mcp-inspector/ {
        set $mcp_upstream "http://${MCP_HOST}:${MCP_PORT}";
        proxy_pass $mcp_upstream/api/inspector/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
    }
    
    # Proxy API Inspector UI requests (for Admin Portal iframe)
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location /api/inspector/ {
        set $mcp_upstream "http://${MCP_HOST}:${MCP_PORT}";
        proxy_pass $mcp_upstream/api/inspector/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Pass through Authorization header for authentication
        proxy_set_header Authorization $http_authorization;
        proxy_pass_header Authorization;
        proxy_buffering off;
    }
    
    # Proxy MCP Orchestrator UI
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location /mcp-orchestrator/ {
        set $mcp_upstream "http://${MCP_HOST}:${MCP_PORT}";
        proxy_pass $mcp_upstream/ui/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
    }
    
    # Proxy MCP Orchestrator WebSocket
    # NOTE: Using variable for proxy_pass enables runtime DNS resolution (requires resolver)
    location /api/mcp-orchestrator/ws {
        set $mcp_upstream "http://${MCP_HOST}:${MCP_PORT}";
        proxy_pass $mcp_upstream/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # ===========================================
    # REDIS COMMANDER PROXY
    # ===========================================
    # Admin tool for Redis inspection and debugging
    # NOTE: No auth_request - embedded in already-authenticated Admin Portal
    # Redis Commander runs with authentication DISABLED (no HTTP_USER/HTTP_PASSWORD)
    # Access is controlled by Admin Portal authentication (is_admin check)
    # NOTE: Using variable for proxy_pass to allow runtime DNS resolution (Redis Commander may not be deployed)
    location ^~ /redis-commander/ {
        set $redis_commander_upstream "http://${REDIS_COMMANDER_HOST}:${REDIS_COMMANDER_PORT}";
        proxy_pass $redis_commander_upstream/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;

        # Allow iframe embedding from same origin
        proxy_hide_header X-Frame-Options;
        proxy_hide_header Content-Security-Policy;
    }

    # ===========================================
    # ATTU (MILVUS ADMIN) PROXY
    # ===========================================
    # ===========================================
    # GRAFANA — Monitoring dashboards (Admin-only via auth subrequest)
    # ===========================================
    location ^~ /grafana/ {
        auth_request /internal/auth/verify;
        set $grafana_upstream "http://grafana.monitoring-stack.svc.cluster.local:3000";
        proxy_pass $grafana_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
        # Allow iframe embedding from Admin Console
        proxy_hide_header X-Frame-Options;
        proxy_hide_header Content-Security-Policy;
    }

    # Admin tool for Milvus vector database
    # NOTE: No auth_request - embedded in already-authenticated Admin Portal
    # Milvus itself is on internal network only, Attu provides the admin UI
    # NOTE: Using variable for proxy_pass to allow runtime DNS resolution (Attu may not be deployed)
    location ^~ /attu/ {
        set $attu_main_upstream "http://${ATTU_HOST}:${ATTU_PORT}";
        proxy_pass $attu_main_upstream/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;

        # Allow iframe embedding from same origin
        proxy_hide_header X-Frame-Options;
        proxy_hide_header Content-Security-Policy;

        # Disable gzip to allow sub_filter if needed
        proxy_set_header Accept-Encoding "";
    }

    # Serve Documentation (Docusaurus) from local build
    # Redirect /docs to /docs/ai/ where the main index.html exists
    location = /docs {
        return 301 /docs/ai/;
    }

    location /docs/ {
        alias /usr/share/nginx/html/docs/;
        try_files $uri $uri/ /docs/ai/index.html;

        # Allow iframe embedding from same origin for DocsViewer
        add_header X-Frame-Options "SAMEORIGIN" always;

        # Never cache JSON files (documentation index, etc.)
        location ~* \.json$ {
            add_header Cache-Control "no-cache, no-store, must-revalidate";
            add_header Pragma "no-cache";
            add_header Expires "0";
        }

        # Cache documentation assets
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 7d;
            add_header Cache-Control "public, immutable";
        }
    }
    
    # Serve static assets
    location /assets/ {
        root /usr/share/nginx/html;
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Serve config.js with no caching
    location = /config.js {
        root /usr/share/nginx/html;
        try_files $uri =404;
        add_header Content-Type application/javascript;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";
    }

    # Cache other static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Serve frontend for all other routes - with no-cache for HTML
    location / {
        try_files $uri $uri/ /index.html;
        # Prevent caching of HTML files to ensure fresh JavaScript references
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";
    }
    
    # Nginx stub_status for metrics (only accessible internally)
    location /nginx_status {
        stub_status on;
        access_log off;
        allow 127.0.0.1;
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        deny all;
    }

    # Enable gzip compression
    gzip on;
    gzip_types text/plain text/css text/javascript application/javascript application/json;
    gzip_min_length 1000;
}
