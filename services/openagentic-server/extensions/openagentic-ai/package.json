{
  "name": "openagentic",
  "displayName": "OpenAgentic AI",
  "description": "AI-powered code assistance via the OpenAgentic Code Mode - streaming chat, tool calls, and file operations",
  "version": "1.1.0",
  "publisher": "openagentic",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "openagentic",
    "openagentic",
    "claude",
    "code-assistant",
    "chat"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "openagentic.openChat",
        "title": "Open AI Chat",
        "category": "OpenAgentic",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "openagentic.terminalDisabled",
        "title": "Terminal (Disabled for Security)",
        "category": "OpenAgentic",
        "icon": "$(terminal)"
      },
      {
        "command": "openagentic.clearActivity",
        "title": "Clear Activity",
        "category": "OpenAgentic",
        "icon": "$(clear-all)"
      },
      {
        "command": "openagentic.explainCode",
        "title": "Explain Selected Code",
        "category": "OpenAgentic",
        "icon": "$(lightbulb)"
      },
      {
        "command": "openagentic.refactorCode",
        "title": "Refactor Selected Code",
        "category": "OpenAgentic",
        "icon": "$(edit)"
      },
      {
        "command": "openagentic.generateTests",
        "title": "Generate Tests for Code",
        "category": "OpenAgentic",
        "icon": "$(beaker)"
      },
      {
        "command": "openagentic.fixCode",
        "title": "Fix Code Issues",
        "category": "OpenAgentic",
        "icon": "$(wrench)"
      },
      {
        "command": "openagentic.addDocumentation",
        "title": "Add Documentation",
        "category": "OpenAgentic",
        "icon": "$(book)"
      },
      {
        "command": "openagentic.askAboutCode",
        "title": "Ask AI About Selection...",
        "category": "OpenAgentic",
        "icon": "$(question)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "openagentic.contextMenu",
          "group": "OpenAgentic",
          "when": "editorHasSelection"
        }
      ],
      "openagentic.contextMenu": [
        {
          "command": "openagentic.explainCode",
          "group": "1_understand"
        },
        {
          "command": "openagentic.refactorCode",
          "group": "2_modify"
        },
        {
          "command": "openagentic.fixCode",
          "group": "2_modify"
        },
        {
          "command": "openagentic.addDocumentation",
          "group": "3_docs"
        },
        {
          "command": "openagentic.generateTests",
          "group": "4_tests"
        },
        {
          "command": "openagentic.askAboutCode",
          "group": "5_ask"
        }
      ]
    },
    "submenus": [
      {
        "id": "openagentic.contextMenu",
        "label": "OpenAgentic AI"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openagentic-panel",
          "title": "OpenAgentic",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "openagentic-panel": [
        {
          "type": "webview",
          "id": "openagentic.chatView",
          "name": "AI Chat"
        },
        {
          "id": "openagentic.activity",
          "name": "Activity"
        }
      ]
    },
    "configuration": {
      "title": "OpenAgentic AI",
      "properties": {
        "openagentic.managerUrl": {
          "type": "string",
          "default": "",
          "description": "OpenAgentic Manager URL (usually set automatically via environment)"
        },
        "openagentic.userId": {
          "type": "string",
          "default": "",
          "description": "User ID for session management"
        },
        "openagentic.sessionId": {
          "type": "string",
          "default": "",
          "description": "Session ID to connect to (leave empty for new session)"
        },
        "openagentic.token": {
          "type": "string",
          "default": "",
          "description": "Authentication token"
        }
      }
    },
    "keybindings": [
      {
        "command": "openagentic.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "openagentic.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "openagentic.askAboutCode",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
