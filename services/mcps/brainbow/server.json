{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.agentic-work/brainbow",
  "description": "Programmable shared browser + live-vision narrator for AI agents (default local Ollama).",
  "version": "0.7.1",
  "repository": {
    "url": "https://github.com/agentic-work/brainbow",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@agenticwork/brainbow",
      "version": "0.7.1",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BRAINBOW_URL",
          "description": "Existing brainbow REST URL (skips autostart)",
          "isRequired": false
        },
        {
          "name": "BRAINBOW_VISION_PROVIDER",
          "description": "ollama|bedrock|anthropic|openai",
          "isRequired": false
        },
        {
          "name": "BRAINBOW_OLLAMA_HOST",
          "description": "Ollama base URL",
          "isRequired": false
        }
      ]
    }
  ]
}
