{
  "name": "openagentic-api",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "TypeScript API for OpenAgentic Platform",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:data-layer": "tsx src/tests/data-layer/runner.ts",
    "test:data-layer:quick": "tsx src/tests/data-layer/runner.ts --quick",
    "test:data-layer:postgres": "tsx src/tests/data-layer/runner.ts --postgres-only",
    "test:data-layer:redis": "tsx src/tests/data-layer/runner.ts --redis-only",
    "test:data-layer:milvus": "tsx src/tests/data-layer/runner.ts --milvus-only",
    "test:data-layer:json": "tsx src/tests/data-layer/runner.ts --json",
    "validate": "tsx src/tests/data-layer/runner.ts --quick",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed:prompts": "tsx prisma/seed-prompts.ts",
    "ingest:knowledge": "tsx src/scripts/ingest-knowledge.ts",
    "ingest:docs": "tsx src/scripts/ingest-knowledge.ts -- --docs-only",
    "ingest:chats": "tsx src/scripts/ingest-knowledge.ts -- --chats-only",
    "ingest:recent": "tsx src/scripts/ingest-knowledge.ts -- --last-7-days",
    "generate-swagger": "tsx scripts/generate-swagger.ts",
    "agentic-loop": "tsx src/test/agentic-loop/index.ts",
    "agentic-loop:client": "tsx src/test/agentic-loop/client.ts",
    "ollama-harness": "tsx src/test/ollama-harness.ts",
    "ollama-harness:watch": "tsx src/test/ollama-harness.ts --watch",
    "hal": "tsx src/test/agentic-loop/hal-client.ts",
    "hal:validate": "tsx src/test/agentic-loop/hal-client.ts validate",
    "hal:review": "tsx src/test/agentic-loop/hal-client.ts review",
    "postbuild:assets": "mkdir -p dist/agents/built-in && cp src/agents/built-in/*.md dist/agents/built-in/ 2>/dev/null || true; mkdir -p dist/services/pricing/data && cp src/services/pricing/data/*.json dist/services/pricing/data/ 2>/dev/null || true"
  },
  "dependencies": {
    "@agentic-work/llm-sdk": "workspace:*",
    "@anthropic-ai/foundry-sdk": "latest",
    "@anthropic-ai/sdk": "^0.87.0",
    "@aws-sdk/client-bedrock": "^3.1028.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1028.0",
    "@aws-sdk/client-pricing": "^3.1008.0",
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "@azure/arm-appservice": "^17.0.0",
    "@azure/arm-compute": "^23.0.0",
    "@azure/arm-resources": "^7.0.0",
    "@azure/arm-subscriptions": "^5.1.0",
    "@azure/identity": "^4.13.1",
    "@azure/monitor-query": "^1.3.3",
    "@azure/msal-node": "^2.16.3",
    "@azure/storage-blob": "^12.29.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.0.1",
    "@fastify/static": "^8.0.2",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/websocket": "^11.0.0",
    "@google-cloud/storage": "^7.17.3",
    "@google/genai": "^1.49.0",
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.17.3",
    "@openagentic/workflow-engine": "workspace:*",
    "@prisma/client": "^6.16.2",
    "@smithy/node-http-handler": "^4.4.7",
    "@types/glob": "^8.1.0",
    "@types/node-jose": "^1.1.13",
    "@zilliz/milvus2-sdk-node": "2.6.5",
    "archiver": "^7.0.1",
    "axios": "^1.12.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.3",
    "canvas": "^2.11.2",
    "chart.js": "^4.5.0",
    "chartjs-node-canvas": "^4.1.6",
    "chokidar": "^4.0.3",
    "docx": "9.6.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "glob": "^11.1.0",
    "google-auth-library": "^9.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.2",
    "jwks-rsa": "^3.1.0",
    "katex": "^0.16.11",
    "mammoth": "^1.8.0",
    "markdown-it": "^14.0.0",
    "mermaid": "^11.5.0",
    "minio": "^8.0.6",
    "monaco-editor": "^0.52.0",
    "nanoid": "^5.0.9",
    "node-fetch": "^3.3.2",
    "node-jose": "^2.2.0",
    "nodemailer": "^6.9.13",
    "ollama": "^0.6.3",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "puppeteer": "^23.11.1",
    "redis": "^4.7.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-emoji": "^5.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.33.5",
    "shiki": "^1.22.0",
    "undici": "^7.5.0",
    "unified": "^11.0.5",
    "unzipper": "^0.12.3",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "ws": "^8.18.3",
    "xml2js": "^0.6.2",
    "zod": "^3.24.1",
    "xlsx": "^0.18.5",
    "@aws-sdk/client-sts": "^3.700.0",
    "echarts": "^5.5.0",
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@prisma/engines": "^6.16.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "prisma": "^6.16.2",
    "prisma-dbml-generator": "^0.12.0",
    "prisma-erd-generator": "^2.0.4",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "glob": "^11.1.0",
    "inflight": "npm:@isaacs/ttlcache@^1.4.1",
    "@grpc/grpc-js": "^1.12.4",
    "cross-spawn": "^7.0.6",
    "mermaid": "^11.5.0",
    "tmp": "^0.2.3",
    "tar-fs": "^3.0.6",
    "esbuild": "^0.27.0",
    "chart.js": "^4.5.0",
    "vite": "^5.4.11",
    "fast-xml-parser": "^5.3.5",
    "lodash-es": "^4.17.21"
  }
}
