// ============================================================================
// LLM PROVIDER CONFIGURATION (admin schema)
// ============================================================================

model LLMProvider {
  id            String  @id @default(uuid())
  name          String  @unique // e.g., "azure-openai-prod", "vertex-ai-main"
  display_name  String // User-friendly name
  provider_type String // "azure-openai" | "vertex-ai" | "aws-bedrock"
  enabled       Boolean @default(true)
  priority      Int     @default(1) // Lower = higher priority

  // Authentication configuration (stored as JSON for flexibility)
  // For Azure: { type: "api-key", key: "..." } OR { type: "entra-id", tenantId: "...", clientId: "...", clientSecret: "..." }
  // For Vertex: { type: "api-key", key: "..." } OR { type: "service-account", credentials: "base64..." }
  // For Bedrock: { type: "iam-keys", accessKeyId: "...", secretAccessKey: "...", region: "..." }
  auth_config Json

  // Provider-specific configuration
  // For Azure: { endpoint: "...", deployment: "...", apiVersion: "..." }
  // For Vertex: { projectId: "...", location: "..." }
  // For Bedrock: { region: "...", modelId: "..." }
  provider_config Json

  // Model configuration
  // { maxTokens: 16000, temperature: 1.0, topP: 1.0, frequencyPenalty: 0, presencePenalty: 0 }
  model_config Json @default("{}")

  // Capabilities
  // { chat: true, embeddings: true, vision: false, tools: true, streaming: true }
  capabilities Json @default("{}")

  // Metadata
  description            String?
  tags                   String[] @default([])
  created_by             String?
  updated_by             String?
  credentials_expires_at DateTime? // When auth_config credentials expire (for key rotation tracking)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  // Soft delete
  deleted_at DateTime?

  // Relations
  creator User? @relation("LLMProviderCreator", fields: [created_by], references: [id])
  updater User? @relation("LLMProviderUpdater", fields: [updated_by], references: [id])

  @@index([provider_type])
  @@index([enabled])
  @@index([priority])
  @@map("llm_providers")
  @@schema("admin")
}

// ============================================================================
// AGENTIC FRAMEWORKS - Runtime configuration for external agent frameworks
// DEPRECATED 2026-04-11 v0.6.3: langgraph/crewai framework values removed.
// The native workflow engine is the primary orchestration layer. This table
// remains for future external-framework integrations (e.g., autogen).
// ============================================================================

enum AgenticFrameworkType {
  autogen
  custom
  // DEPRECATED 2026-04-11 v0.6.3 - dead framework services removed
  // langgraph
  // crewai

  @@schema("admin")
}

model AgenticFramework {
  id             String               @id @default(uuid())
  name           String               @unique // e.g., "autogen-primary"
  display_name   String               // User-friendly name
  framework_type AgenticFrameworkType
  enabled        Boolean              @default(true)
  priority       Int                  @default(1) // Lower = higher priority (for load balancing)

  // Service configuration
  // { host: "http://service:port", healthEndpoint: "/health", metricsEndpoint: "/metrics" }
  service_config Json

  // LLM Configuration - which LLM to use for this framework
  // { provider: "ollama", model: "qwen2.5:32b-instruct", temperature: 0.7, maxTokens: 8192 }
  llm_config Json @default("{}")

  // Framework-specific configuration (schema depends on framework_type)
  framework_config Json @default("{}")

  // Capabilities this framework supports
  // { research: true, coding: true, workflows: true, tools: ["web_search", "memory"] }
  capabilities Json @default("{}")

  // Rate limiting and resource constraints
  // { maxConcurrent: 10, maxRequestsPerMinute: 60, timeoutMs: 300000 }
  resource_limits Json @default("{}")

  // Metadata
  description String?  @db.Text
  tags        String[] @default([])
  version     String?
  created_by  String?
  updated_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Soft delete
  deleted_at DateTime?

  // Relations
  creator User? @relation("AgenticFrameworkCreator", fields: [created_by], references: [id])
  updater User? @relation("AgenticFrameworkUpdater", fields: [updated_by], references: [id])
  status  AgenticFrameworkStatus?
  crews   AgenticCrew[]

  @@index([framework_type])
  @@index([enabled])
  @@index([priority])
  @@map("agentic_frameworks")
  @@schema("admin")
}

model AgenticFrameworkStatus {
  framework_id     String    @id
  status           String    @default("unknown") // "healthy", "degraded", "unhealthy", "unknown"
  last_check_at    DateTime?
  last_error       String?   @db.Text
  response_time_ms Int?

  // Metrics from last health check
  active_sessions Int   @default(0)
  total_requests  Int   @default(0)
  error_count     Int   @default(0)
  avg_latency_ms  Float?

  updated_at DateTime @updatedAt

  framework AgenticFramework @relation(fields: [framework_id], references: [id], onDelete: Cascade)

  @@map("agentic_framework_status")
  @@schema("admin")
}

// Crew/Agent definitions that can be deployed to frameworks
model AgenticCrew {
  id           String  @id @default(uuid())
  framework_id String
  name         String
  display_name String
  description  String? @db.Text

  // Crew configuration
  // { agents: [...], tasks: [...], process: "sequential", memory: true }
  crew_config Json

  // Input/Output schema
  input_schema  Json? @default("{}")
  output_schema Json? @default("{}")

  enabled     Boolean  @default(true)
  is_template Boolean  @default(false) // If true, can be cloned
  tags        String[] @default([])
  created_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  framework AgenticFramework @relation(fields: [framework_id], references: [id], onDelete: Cascade)

  @@unique([framework_id, name])
  @@index([framework_id])
  @@index([enabled])
  @@map("agentic_crews")
  @@schema("admin")
}

// ============================================================================
// AGENTIC LOOPS - Platform-level agent definitions (graph-based)
// Visible in Admin Portal: OpenAgenticflows > Agents section
// Editable live without code changes
// ============================================================================

// Agent definition - the core building block
model Agent {
  id           String  @id @default(uuid())
  name         String  @unique
  display_name String
  description  String? @db.Text
  agent_type   String
  category     String @default("platform")
  graph_definition Json @default("{}")
  model_config Json
  system_prompt String? @db.Text
  state_schema Json @default("{}")
  input_schema  Json @default("{}")
  output_schema Json @default("{}")
  rate_limits Json @default("{}")
  cost_limits Json @default("{}")
  alert_config Json @default("{}")
  logging_config Json @default("{}")
  enabled    Boolean @default(true)
  is_default Boolean @default(false)
  version    String   @default("1.0.0")
  tags       String[] @default([])
  icon       String?
  color      String?
  prompt_modules  String[] @default([])
  prompt_strategy String   @default("composite")
  prompt_mode     String   @default("full")
  skills          String[] @default([])
  delegation      Json     @default("{}")
  background      Json?
  tools_whitelist String[] @default([])
  tools_deny_list String[] @default([])
  max_spawn_depth Int @default(1)
  max_children    Int @default(5)
  retry_strategy  Json @default("{}")
  handoff_schema  Json @default("{}")
  triggers        String[] @default([])
  isolation       String?  @default("none")
  memory_scope    String?  @default("session")
  created_by String?
  updated_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  versions   AgentVersion[]
  executions AgentRunLog[]
  metrics    AgentMetrics[]
  @@index([agent_type])
  @@index([category])
  @@index([enabled])
  @@index([is_default, agent_type])
  @@map("agentic_loops")
  @@schema("admin")
}

model AgentVersion {
  id          String  @id @default(uuid())
  loop_id     String
  version     Int
  graph_definition Json
  model_config     Json
  system_prompt    String? @db.Text
  state_schema     Json
  changelog   String? @db.Text
  is_active   Boolean @default(false)
  created_by  String?
  created_at  DateTime @default(now())
  agent Agent @relation(fields: [loop_id], references: [id], onDelete: Cascade)
  @@unique([loop_id, version])
  @@index([loop_id])
  @@index([loop_id, is_active])
  @@map("agentic_loop_versions")
  @@schema("admin")
}

model AgentRunLog {
  id          String @id @default(uuid())
  loop_id     String
  session_id  String?
  user_id     String?
  status      String @default("pending")
