// ============================================================================
// MULTI-MODEL COLLABORATION (admin schema)
// Configuration and metrics for multi-model orchestration
// ============================================================================

/// Model role assignments for multi-model collaboration
/// Configures which models handle each role (reasoning, tool_execution, synthesis, fallback)
model ModelRoleAssignment {
  id                  String   @id @default(uuid())
  role                String // 'reasoning', 'tool_execution', 'synthesis', 'fallback'
  model               String // Model identifier (e.g., 'claude-opus-4', 'claude-sonnet-4')
  provider            String // Provider name (e.g., 'anthropic', 'vertex-ai', 'azure-openai')
  priority            Int      @default(0) // Lower = higher priority
  enabled             Boolean  @default(true)
  slider_min_position Int      @default(0) // Minimum slider position to use this model
  slider_max_position Int      @default(100) // Maximum slider position to use this model
  cost_per_request    Decimal? @db.Decimal(10, 6) // Estimated cost per request
  temperature         Float?   @default(0.5)
  max_tokens          Int?
  thinking_budget     Int? // Token budget for extended thinking (reasoning role)
  options             Json?    @default("{}") // Role-specific options
  description         String?
  created_by          String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  creator User @relation(fields: [created_by], references: [id])

  @@unique([role, model, provider])
  @@index([role, enabled])
  @@index([slider_min_position, slider_max_position])
  @@index([priority])
  @@map("model_role_assignments")
  @@schema("admin")
}

/// Multi-model orchestration metrics
/// Tracks performance and cost of multi-model requests
model MultiModelMetrics {
  id               String  @id @default(uuid())
  orchestration_id String  @unique // Unique ID for the multi-model request
  session_id       String?
  user_id          String

  // Execution details
  roles_executed String[] // Array of roles that ran (e.g., ['reasoning', 'tool_execution', 'synthesis'])
  total_handoffs Int      @default(0)
  success        Boolean  @default(true)
  error_message  String?

  // Per-role metrics (JSON with breakdown per role)
  role_metrics Json? @default("{}") // { reasoning: {...}, tool_execution: {...}, ... }

  // Aggregates
  total_input_tokens    Int     @default(0)
  total_output_tokens   Int     @default(0)
  total_thinking_tokens Int?
  total_cost            Decimal @default(0) @db.Decimal(10, 6)
  total_duration_ms     Int     @default(0)

  // Request context
  complexity      String? // 'simple', 'moderate', 'complex', 'expert'
  slider_position Int?
  routing_reason  String? // Why multi-model was used

  created_at DateTime @default(now())

  user    User         @relation(fields: [user_id], references: [id])
  session ChatSession? @relation(fields: [session_id], references: [id])

  @@index([user_id, created_at])
  @@index([orchestration_id])
  @@index([complexity])
  @@index([success])
  @@index([created_at])
  @@map("multi_model_metrics")
  @@schema("admin")
}

// ============================================================================
// GOOGLE VERTEX CONTEXT CACHE (admin schema)
// Tracks cached content on Google's servers for 90% cost savings
// See: https://ai.google.dev/gemini-api/docs/caching
// ============================================================================

model VertexContentCache {
  id           String  @id @default(uuid())
  cache_name   String  @unique // Google's cache name (e.g., "cachedContents/abc123")
  content_hash String // SHA256 hash of cached content for dedup
  model        String // Model the cache was created for (e.g., "gemini-2.5-pro")

  // Ownership
  user_id    String? // User who created the cache
  session_id String? // Session context

  // Cache metadata
  token_count   Int? // Number of tokens in cached content
  display_name  String?
  usage_count   Int      @default(0) // Times this cache has been used
  last_used_at  DateTime @default(now())

  // TTL tracking
  expires_at DateTime // When the cache expires on Google's servers

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([content_hash, model])
  @@index([user_id])
  @@index([session_id])
  @@index([model])
  @@index([expires_at])
  @@index([content_hash])
  @@map("vertex_content_caches")
  @@schema("admin")
}

// ============================================================================
// PGVECTOR SEMANTIC QUERY CACHE (public schema)
// Stores query embeddings for semantic deduplication and similarity search
// Used with pgvector for ACID-compliant transactional data (<100K vectors)
// See: DATA_LAYER_EVOLUTION_PLAN.md for architecture decisions
// ============================================================================

model QueryEmbeddingCache {
  id           String   @id @default(uuid())
  query_hash   String   @unique // SHA256 of normalized query for exact match
  query_text   String   @db.Text // Original query text
  normalized   String   @db.Text // Normalized/cleaned query for matching

  // Context for the query
  context_type String   @default("chat") // 'chat', 'tool', 'prompt', 'search'
  user_id      String?  // Optional user scope
  session_id   String?  // Optional session scope

  // Cached response/result
  cached_response Json?  // Cached LLM/tool response (null if just for dedup)
  response_model  String? // Model that generated the response

  // Usage tracking
  hit_count    Int      @default(0)
  last_hit_at  DateTime @default(now())
  miss_cost    Decimal? @db.Decimal(10, 6) // Cost if cache missed

  // Quality/validation
  is_validated Boolean  @default(false) // Response verified by user
  feedback     String?  // User feedback on cached response

  // TTL
  expires_at   DateTime? // Cache expiration

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // pgvector embedding for semantic similarity search (managed via raw SQL)
  // Use PrismaVectorClient.findSimilar() for similarity queries
  embedding Unsupported("vector")?

  @@index([query_hash])
  @@index([context_type])
  @@index([user_id])
  @@index([session_id])
  @@index([hit_count])
  @@index([expires_at])
  @@map("query_embedding_cache")
  @@schema("public")
}

// ============================================================================
// VERIFIED TOOL RESULTS (public schema)
// Stores tool execution results with embeddings for learning
// Uses pgvector for transactional ACID guarantees
// ============================================================================

model VerifiedToolResult {
  id           String   @id @default(uuid())
  tool_name    String   // MCP tool name
  server_id    String   // MCP server ID

  // Input/output
  input_hash   String   // Hash of tool input for dedup
  input_params Json     // Tool input parameters
  result       Json     // Tool result
  result_summary String? @db.Text // Human-readable summary

  // Verification
  is_verified   Boolean  @default(false) // Verified by user/admin
  verified_by   String?  // User ID who verified
  verified_at   DateTime?
  verification_type String? // 'user', 'admin', 'auto'

  // Quality metrics
  quality_score Float?   // 0-1 quality score
  use_count     Int      @default(0)
  last_used_at  DateTime @default(now())

  // Context
  user_id       String?  // User who created
  session_id    String?  // Session context

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // pgvector embedding for semantic result search
  embedding Unsupported("vector")?

  // Relations
  verifications ToolResultVerification[]

  @@unique([tool_name, server_id, input_hash])
  @@index([tool_name])
  @@index([server_id])
  @@index([is_verified])
  @@index([quality_score])
  @@index([use_count])
  @@index([user_id])  // User isolation index for NIST 800-53 / HIPAA compliance
  @@map("verified_tool_results")
  @@schema("public")
}

// ============================================================================
// TOOL RESULT VERIFICATION (public schema)
// Tracks individual verifications for tool results
// ============================================================================

model ToolResultVerification {
  id           String   @id @default(uuid())
  result_id    String   // FK to VerifiedToolResult

  // Verification details
  verification_type String  // 'user', 'system', 'llm', 'provider'
  verifier_id       String? // user_id or model name
  confidence        Float   @default(1.0) // 0-1 confidence
  notes             String? @db.Text

  // Result
  is_positive  Boolean  @default(true) // true = confirms, false = disputes

  created_at   DateTime @default(now())

  // Relations
  result       VerifiedToolResult @relation(fields: [result_id], references: [id], onDelete: Cascade)

  @@index([result_id])
  @@index([verification_type])
  @@index([is_positive])
  @@map("tool_result_verifications")
  @@schema("public")
}

// ============================================================================
// KNOWLEDGE FACTS (public schema)
// Triple-verified facts with embeddings for grounding/hallucination prevention
// Uses pgvector for ACID guarantees on verified knowledge
// ============================================================================

model KnowledgeFact {
  id           String   @id @default(uuid())

  // Fact content
  subject      String   // Entity the fact is about
  predicate    String   // Relationship/property
  object       String   @db.Text // Value/related entity
  confidence   Float    @default(0.5) // 0-1 confidence score

  // Source attribution
  source_type  String   // 'document', 'user', 'tool', 'llm', 'admin'
  source_id    String?  // Reference to source (doc ID, user ID, etc.)
  source_url   String?  // URL if external source

  // Verification (triple verification)
  verification_count Int      @default(0) // Number of verifications
  last_verified_at   DateTime?
  verified_by_types  String[] @default([]) // ['user', 'llm', 'admin']

  // Scope
  is_global    Boolean  @default(false) // Global or user-specific
  user_id      String?  // Owner if not global
  domain       String?  // Knowledge domain (e.g., 'kubernetes', 'azure')

  // Usage
  use_count    Int      @default(0)
  last_used_at DateTime @default(now())

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // pgvector embedding for semantic fact search
  embedding Unsupported("vector")?

  // Relations
  verifications       KnowledgeVerification[]
  contradictions      KnowledgeContradiction[] @relation("ContradictedFact")
  contradicts_facts   KnowledgeContradiction[] @relation("ContradictingFact")

  @@index([subject])
  @@index([predicate])
  @@index([domain])
  @@index([is_global])
  @@index([user_id])
  @@index([confidence])
  @@index([verification_count])
  @@map("knowledge_facts")
  @@schema("public")
}

// ============================================================================
// KNOWLEDGE VERIFICATION (public schema)
// Tracks individual verifications for knowledge facts
// ============================================================================

model KnowledgeVerification {
  id           String   @id @default(uuid())
  fact_id      String   // FK to KnowledgeFact

  // Verification details
  verification_type   String   // 'user', 'system', 'llm', 'provider'
  verification_method String?  // 'explicit', 'implicit_usage', 'cross_reference', 'automated_reasoning'
  verifier_id         String?  // user_id or model name
  confidence          Float    @default(1.0) // 0-1 confidence
  notes               String?  @db.Text

  // Result
  is_positive  Boolean  @default(true) // true = confirms, false = disputes

  created_at   DateTime @default(now())

  // Relations
  fact         KnowledgeFact @relation(fields: [fact_id], references: [id], onDelete: Cascade)

  @@index([fact_id])
  @@index([verification_type])
  @@index([is_positive])
  @@map("knowledge_verifications")
  @@schema("public")
}

// ============================================================================
// KNOWLEDGE CONTRADICTION (public schema)
// Tracks contradictions between knowledge facts
// ============================================================================

model KnowledgeContradiction {
  id                    String   @id @default(uuid())
  fact_id               String   // The fact being contradicted
  contradicting_fact_id String   // The fact that contradicts

  // Detection details
  detected_by        String   // 'system', 'llm', 'user'
  detection_method   String?  // 'semantic_similarity', 'logical_inference', 'manual'
  contradiction_type String?  // 'direct', 'temporal', 'conditional'

  // Resolution
  resolution_status  String   @default("pending") // 'pending', 'resolved', 'both_valid', 'ignored'
  resolution_notes   String?  @db.Text
  resolved_by        String?  // user_id who resolved

  detected_at        DateTime @default(now())
  resolved_at        DateTime?

  // Relations
  contradicted_fact  KnowledgeFact @relation("ContradictedFact", fields: [fact_id], references: [id], onDelete: Cascade)
  contradicting_fact KnowledgeFact @relation("ContradictingFact", fields: [contradicting_fact_id], references: [id], onDelete: Cascade)

  @@index([fact_id])
  @@index([contradicting_fact_id])
  @@index([resolution_status])
  @@map("knowledge_contradictions")
  @@schema("public")
}

// ============================================================================
// TOOL SUCCESS RECORDS (public schema)
// Tracks successful tool executions in pgvector for per-user learning
// Working set (<10K recent records) — Milvus holds the cross-user archive
// ============================================================================

model ToolSuccessRecord {
  id                String   @id @default(uuid())
  user_id           String
  session_id        String?
  query             String   @db.Text
  tool_name         String
  server_name       String?
  intent_tags       String[] @default([])
  context_tags      String[] @default([])
  success_score     Float    @default(1.0)
  execution_time_ms Int?
  result_summary    String?  @db.VarChar(512)
  metadata          Json?
  created_at        DateTime @default(now())

  // pgvector embedding for semantic search (managed via raw SQL)
  query_embedding   Unsupported("vector")?

  @@index([user_id])
  @@index([tool_name])
  @@index([created_at])
  @@map("tool_success_records")
  @@schema("public")
}

// ============================================================================
// TOOL RESULT CACHE (public schema)
// pgvector L2 tier — between Redis L1 (exact-match) and Milvus L3 (cross-user archive)
// TTL-bounded, ACID-compliant semantic cache for recent tool results
// ============================================================================

model ToolResultCache {
  id               String    @id @default(uuid())
  tenant_id        String?
  tool_name        String
  args_hash        String
  query_text       String    @db.Text
  result           Json
  resource_scope   String?   // "azure:sub-123:rg-prod" for cross-user matching
  is_shared        Boolean   @default(false)
  original_user_id String
  hit_count        Int       @default(0)
  created_at       DateTime  @default(now())
  expires_at       DateTime

  // pgvector embedding for semantic search (managed via raw SQL)
  embedding        Unsupported("vector")?

  @@index([tool_name, args_hash])
  @@index([resource_scope])
  @@index([expires_at])
  @@index([tenant_id, original_user_id])  // User isolation index for NIST 800-53 / HIPAA compliance
  @@map("tool_result_cache")
  @@schema("public")
}

// ============================================================================
// SCHEMA VERSION (admin schema)
// Tracks schema migrations for zero-downtime upgrades
// ============================================================================

model SchemaVersion {
  id           Int      @id @default(autoincrement())
  version      String   // Semantic version (e.g., "1.2.0")
  description  String?  @db.Text
  checksum     String   // Hash of schema at this version
  applied_at   DateTime @default(now())
  applied_by   String?  // User/system that applied
  rollback_sql String?  @db.Text // SQL to rollback this migration
  is_current   Boolean  @default(true)

  @@index([version])
  @@index([is_current])
  @@map("schema_versions")
  @@schema("admin")
}

// ============================================================================
// DOCUMENT RAG (public schema)
// Document storage and chunking for RAG pipelines
// ============================================================================

model Document {
  id              String   @id @default(uuid())
  user_id         String
  session_id      String?                       // Optional: tied to chat session

  // Document metadata
  filename        String
  mime_type        String                        // application/pdf, text/plain, etc.
  file_size        Int                           // bytes
  storage_path    String?                       // path in object storage

  // Processing
  status          String   @default("pending")  // pending, processing, ready, failed
  chunk_count     Int      @default(0)
  total_tokens    Int      @default(0)          // estimated token count
  error           String?  @db.Text

  // Content extraction
  extracted_text  String?  @db.Text             // full extracted text (for small docs)
  language        String?                       // detected language

  // Search
  title           String?
  summary         String?  @db.Text             // LLM-generated summary
  embedding       Unsupported("vector")?        // summary embedding for search

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chunks          DocumentChunk[]

  @@index([user_id])
  @@index([status])
  @@index([session_id])
  @@index([created_at])
  @@map("documents")
  @@schema("public")
}

model DocumentChunk {
  id              String   @id @default(uuid())
  document_id     String

  // Chunk content
  content         String   @db.Text
  chunk_index     Int                           // order within document
  start_offset    Int?                          // character offset in original
  end_offset      Int?

  // Metadata
  section_title   String?                       // detected section heading
  page_number     Int?                          // for PDFs
  token_count     Int      @default(0)

  // Embedding
  embedding       Unsupported("vector")?

  created_at      DateTime @default(now())

  // Relations
  document        Document @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([chunk_index])
  @@map("document_chunks")
  @@schema("public")
}

// ============================================================================
// DYNAMIC TOOLS (public schema)
// One-shot MCP tool generation and execution
// ============================================================================

model DynamicTool {
  id           String   @id @default(uuid())

  // Tool definition
  name         String
  description  String   @db.Text
  schema       Json     // JSON Schema for parameters
  implementation String @db.Text // Generated code

  // Lifecycle
  scope        String   @default("session") // 'session', 'user', 'global'
  session_id   String?
  user_id      String?

  // Security
  required_permissions String[] @default([])
  is_sandboxed Boolean  @default(true)
  approved_by  String?  // user_id who approved
  approved_at  DateTime?

  // Promotion tracking
  execution_count Int    @default(0)
  success_rate    Float  @default(0.0)
  is_promoted     Boolean @default(false) // promoted to persistent MCP
  promoted_to     String? // MCP tool id if promoted

  // Metadata
  created_at   DateTime  @default(now())
  expires_at   DateTime?

  // Relations
  executions   DynamicToolExecution[]

  @@index([session_id])
  @@index([user_id])
  @@index([scope])
  @@index([is_promoted])
  @@map("dynamic_tools")
  @@schema("public")
}

model DynamicToolExecution {
  id           String   @id @default(uuid())
  tool_id      String

  // Execution details
  parameters   Json
  result       Json?
  error        String?  @db.Text

  // Status
  status       String   @default("pending") // 'pending', 'running', 'completed', 'failed'
  duration_ms  Int?

  // Metadata
  executed_by  String   // user_id
  executed_at  DateTime @default(now())

  // Relations
  tool         DynamicTool @relation(fields: [tool_id], references: [id], onDelete: Cascade)

  @@index([tool_id])
  @@index([status])
  @@index([executed_at])
  @@map("dynamic_tool_executions")
  @@schema("public")
}

// ============================================================================
// HALLUCINATION PREVENTION (public schema)
// Tool call attempts and hallucination logging
// ============================================================================

model ToolCallAttempt {
  id           String   @id @default(uuid())

  // Context
  session_id   String
  message_id   String?
  user_id      String

  // Tool info
  tool_name    String
  server_id    String
  parameters   Json

  // Result
  success      Boolean
  result       Json?
  error_type   String?  // 'timeout', 'auth', 'invalid_params', 'server_error', 'not_found'
  error_message String? @db.Text

  // Grounding applied
  grounding_used   Boolean @default(false)
  grounding_sources Json?  // What sources were used for grounding

  // Performance
  duration_ms  Int?

  attempted_at DateTime @default(now())

  @@index([session_id])
  @@index([user_id])
  @@index([tool_name, server_id])
  @@index([success])
  @@index([error_type])
  @@map("tool_call_attempts")
  @@schema("public")
}

model HallucinationLog {
  id           String   @id @default(uuid())

  // Context
  session_id   String
  message_id   String?
  user_id      String

  // Detection
  detection_method  String  // 'automated_reasoning', 'contradiction', 'user_flag', 'cross_verify', 'claim_validation'
  confidence        Float   // 0-1 detection confidence

  // Details
  hallucinated_text String  @db.Text
  correct_info      String? @db.Text
  contradiction_source String? // Where the contradiction was found

  // Resolution
  was_corrected Boolean  @default(false)
  correction    String?  @db.Text

  // Metadata
  detected_at   DateTime @default(now())
  model_used    String?
  provider      String?

  @@index([session_id])
  @@index([user_id])
  @@index([detection_method])
  @@index([detected_at])
  @@map("hallucination_logs")
  @@schema("public")
}

// ============================================================================
// LARGE RESPONSE HANDLING (public schema)
// Store full results when summarized/compressed for LLM context
// ============================================================================

model LargeResponseStorage {
  id           String   @id @default(uuid())

  // Context
  session_id   String
  message_id   String?
  tool_call_id String

  // Tool info
  tool_name    String
  server_id    String

  // Response data
  full_result       String   @db.Text // Complete uncompressed result
  result_hash       String           // For exact match lookups
  original_size     Int              // Bytes
  token_estimate    Int              // Estimated token count

  // Compression info
  compressed_summary   String   @db.Text // What was sent to LLM
  compressed_size      Int
  compression_strategy String   // 'passthrough', 'filter', 'summarize', 'paginate', 'hierarchical'
  information_loss     String   // 'none', 'minimal', 'moderate', 'significant'

  // Query-aware filtering
  user_query       String   @db.Text // Original user question
  extracted_filter Json?             // Filter criteria derived from query

  // Pagination state
  total_items   Int?
  items_shown   Int?
  current_page  Int      @default(1)
  has_more      Boolean  @default(false)

  // TTL
  created_at    DateTime @default(now())
  expires_at    DateTime // Auto-cleanup after N hours

  @@index([session_id])
  @@index([tool_call_id])
  @@index([result_hash])
  @@index([expires_at])
  @@map("large_response_storage")
  @@schema("public")
}

// ============================================================================
// TOOL RESULT INTERPRETATION VALIDATION (public schema)
// Validate LLM claims against actual tool results
// ============================================================================

model ToolResultInterpretation {
  id           String   @id @default(uuid())

  // Context
  session_id   String
  message_id   String
  tool_call_id String

  // Raw data
  raw_result   String   @db.Text // Original tool result
  result_hash  String            // For matching against stored results

  // LLM interpretation
  llm_summary  String   @db.Text // What LLM said about the result
  llm_model    String            // Model that generated interpretation

  // Validation results
  validation_status String        // 'valid', 'suspicious', 'invalid'
  confidence_score  Float         // 0-1 overall confidence
  warnings          String[] @default([])

  // Outcome
  regenerated  Boolean  @default(false) // Was response regenerated?

  validated_at DateTime @default(now())

  // Relations
  claims       InterpretationClaim[]

  @@index([session_id])
  @@index([tool_call_id])
  @@index([validation_status])
  @@map("tool_result_interpretations")
  @@schema("public")
}

model InterpretationClaim {
  id                String   @id @default(uuid())
  interpretation_id String

  // Claim details
  claim_text   String   @db.Text
  claim_type   String   // 'count', 'name', 'status', 'existence', 'comparison'
  importance   String   // 'critical', 'normal', 'minor'

  // Validation result
  status       String   // 'verified', 'unverifiable', 'contradicted'
  evidence     String?  @db.Text // Where in result this was found/contradicted
  match_type   String?  // 'exact', 'semantic', 'structural'

  // Relations
  interpretation ToolResultInterpretation @relation(fields: [interpretation_id], references: [id], onDelete: Cascade)

  @@index([interpretation_id])
  @@index([status])
  @@index([claim_type])
  @@map("interpretation_claims")
  @@schema("public")
}

// ============================================================================
// AUTOMATIC TOOL SUCCESS SCORING (public schema)
// Derive quality scores for tool executions automatically
// ============================================================================

model ToolExecutionScore {
  id           String   @id @default(uuid())

  // Context
  session_id   String
  message_id   String?
  tool_call_id String   @unique

  // Tool info
  tool_name    String
  server_id    String

  // Execution signals (immediate - 30% weight)
  exec_http_success      Boolean
  exec_response_time_ms  Int
  exec_result_size       Int
  exec_no_error_flag     Boolean
  exec_score             Float   // 0-1

  // Structural signals (post-parse - 25% weight)
  struct_valid_format    Boolean
  struct_expected_fields Float   // % of expected fields present
  struct_correct_types   Float   // % of fields with correct type
  struct_no_error_fields Boolean
  struct_score           Float   // 0-1

  // Semantic signals (LLM-judged - 25% weight, async)
  semantic_answers_query Float?  // 0-1
  semantic_specificity   Float?  // 0-1
  semantic_consistency   Float?  // 0-1
  semantic_score         Float?  // 0-1

  // Behavioral signals (updated over time - 20% weight)
  behavior_user_continued   Boolean @default(false)
  behavior_followup_asked   Boolean @default(false)
  behavior_retried          Boolean @default(false)
  behavior_explicit_feedback String? // 'positive', 'negative', null
  behavior_score            Float   @default(0.5) // 0-1

  // Combined scores
  final_score  Float    // Weighted combination
  confidence   Float    // How confident in this score

  scored_at    DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([session_id])
  @@index([tool_name, server_id])
  @@index([final_score])
  @@map("tool_execution_scores")
  @@schema("public")
}

model ToolReliabilityAggregate {
  id           String   @id @default(uuid())

  // Tool identity
  tool_name    String
  server_id    String

  // Aggregate statistics
  total_executions Int     @default(0)
  average_score    Float   @default(0.0)
  score_std_dev    Float   @default(0.0)
  min_score        Float?
  max_score        Float?

  // Recent history (for trend analysis)
  recent_scores    Float[] @default([]) // Last 10 executions
  score_trend      String  @default("stable") // 'improving', 'stable', 'degrading'

  // Reliability tier
  tier             String  @default("untrusted") // 'gold', 'silver', 'bronze', 'untrusted'
  // gold: >0.9 avg, >100 executions
  // silver: >0.7 avg, >50 executions
  // bronze: >0.5 avg, >10 executions
  // untrusted: <0.5 or <10 executions

  first_seen_at    DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([tool_name, server_id])
  @@index([tier])
  @@index([average_score])
  @@map("tool_reliability_aggregates")
  @@schema("public")
}

// ============================================================================
// WORKFLOW PLATFORM - Core workflow definitions (NEW)
// ============================================================================

model Workflow {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  // ReactFlow definition
  definition Json // { nodes: [], edges: [] }
  triggers   Json @default("[]") // Webhook, schedule, event configs
  settings   Json @default("{}") // Global workflow settings
  variables  Json @default("{}") // Workflow-level variables

  // Ownership
  created_by String
  group_id   String?

  // Status
  is_active   Boolean @default(true)
  is_template Boolean @default(false)
  is_public   Boolean @default(false)

  // Metadata
  tags     String[] @default([])
  category String?
  icon     String?
  color    String?

  // Statistics
  total_executions      Int     @default(0)
  successful_executions Int     @default(0)
  failed_executions     Int     @default(0)
  avg_execution_time_ms Int?
  total_cost            Decimal @default(0) @db.Decimal(10, 6)

  // Rate limiting
  max_concurrent_executions Int     @default(5)
  max_executions_per_hour   Int     @default(100)
  max_cost_per_execution    Decimal @default(10) @db.Decimal(10, 2)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime? // Soft delete

  // pgvector embedding for semantic search (managed via raw SQL)
  embedding  Unsupported("vector")?

  // Relations
  creator    User               @relation(fields: [created_by], references: [id])
  group      UserGroup?         @relation(fields: [group_id], references: [id])
  versions   WorkflowVersion[]
  executions WorkflowExecution[]
  webhooks   WorkflowWebhook[]
  schedules  WorkflowSchedule[]
  secrets    WorkflowSecret[]
  tests      WorkflowTest[]

  @@index([created_by])
  @@index([group_id])
  @@index([is_active])
  @@index([category])
  @@index([is_template, is_public])
  @@map("workflows")
  @@schema("public")
}

model WorkflowVersion {
  id          String  @id @default(uuid())
  workflow_id String
  version     Int
  definition  Json
  triggers    Json    @default("[]")
  settings    Json    @default("{}")
  changelog   String? @db.Text
  is_active   Boolean @default(false)
  created_by  String
  created_at  DateTime @default(now())

  workflow Workflow            @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  creator  User                @relation(fields: [created_by], references: [id])
  executions WorkflowExecution[]

  @@unique([workflow_id, version])
  @@index([workflow_id])
  @@index([workflow_id, is_active])
  @@map("workflow_versions")
  @@schema("public")
}

model WorkflowExecution {
  id          String  @id @default(uuid())
  workflow_id String
  version_id  String?

  // Trigger info
  trigger_type String // webhook, schedule, manual, event, api
  trigger_data Json?
  webhook_id   String?

  // Execution state (persistent for resume)
  status          String @default("pending") // pending, running, paused, completed, failed, cancelled
  current_node_id String?
  state           Json   @default("{}")
  node_outputs    Json   @default("{}")
  checkpoints     Json   @default("[]")

  // Input/Output
  input         Json
  output        Json?
  error         String? @db.Text
  error_node_id String?

  // Metrics
  total_nodes     Int     @default(0)
  completed_nodes Int     @default(0)
  execution_time_ms Int?
  cost            Decimal @default(0) @db.Decimal(10, 6)

  // Ownership
  started_by String?
  group_id   String?

  // Timing
  started_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  completed_at DateTime?
  paused_at    DateTime?
  resume_at    DateTime? // Scheduled resume time

  // Relations
  workflow  Workflow             @relation(fields: [workflow_id], references: [id])
  version   WorkflowVersion?     @relation(fields: [version_id], references: [id])
  starter   User?                @relation(fields: [started_by], references: [id])
  group     UserGroup?           @relation(fields: [group_id], references: [id])
  approvals    WorkflowApproval[]
  dataRequests WorkflowDataRequest[]
  logs      WorkflowExecutionLog[]
  tokenUsage TokenUsage[]

  @@index([workflow_id])
  @@index([status])
  @@index([started_by])
  @@index([started_at])
  @@index([webhook_id])
  @@map("workflow_executions")
  @@schema("public")
}

model WorkflowApproval {
  id           String @id @default(uuid())
  execution_id String
  node_id      String

  // Approval configuration
  required_approvers String[] // User IDs or group names
  required_count     Int      @default(1)
  timeout_seconds    Int      @default(86400) // 24 hours
  timeout_action     String   @default("reject") // approve, reject, escalate

  // Approval status
  status       String   @default("pending") // pending, approved, rejected, timeout, escalated
  approved_by  String[] @default([])
  rejected_by  String?
  escalated_to String[] @default([])

  // Context
  message      String? @db.Text
  context_data Json?
  response     String? @db.Text

  // Notifications
  notification_channels String[] @default([])
  notifications_sent    Json     @default("[]")

  // Timing
  created_at DateTime  @default(now())
  timeout_at DateTime
  decided_at DateTime?

  // Relations
  execution WorkflowExecution @relation(fields: [execution_id], references: [id], onDelete: Cascade)
  rejector  User?             @relation(fields: [rejected_by], references: [id])

  @@index([execution_id])
  @@index([status])
  @@map("workflow_approvals")
  @@schema("public")
}

// HITL human_input / request_data — the typed DATA-REQUEST gate (sister of
// WorkflowApproval). A human_input node persists one of these rows, pauses the
// run, and emits a `needs_input` frame; POST /resume-execution validates the
// user's submitted values against the stored fields[] and resumes the engine.
model WorkflowDataRequest {
  id           String @id @default(uuid())
  execution_id String
  node_id      String

  // The typed form the user must fill (array of field descriptors).
  fields      Json
  title       String? @db.Text
  description String? @db.Text

  // Request configuration
  timeout_seconds Int      @default(86400) // 24 hours
  timeout_action  String   @default("fail") // fail | use_default
  assign_to       String[] @default([]) // user ids or group names allowed to answer
  channel         String   @default("chat") // chat | in_app | email | slack

  // Status + result
  status      String  @default("pending") // pending, provided, timeout
  values      Json? // the user's submitted answers, keyed by field name
  provided_by String? // user id who submitted

  // Context (input snapshot + node results at suspend time)
  context_data Json?

  // Multi-tenant isolation (nullable / harmless in single-tenant OSS)
  tenant_id String?

  // Timing
  created_at DateTime  @default(now())
  timeout_at DateTime
  decided_at DateTime?

  // Relations
  execution WorkflowExecution @relation(fields: [execution_id], references: [id], onDelete: Cascade)

  @@index([execution_id])
  @@index([status])
  @@index([tenant_id])
  @@map("workflow_data_requests")
  @@schema("public")
}

model WorkflowExecutionLog {
  id           String   @id @default(uuid())
  execution_id String
  node_id      String?
  level        String // debug, info, warn, error
  message      String   @db.Text
  data         Json?
  trace_id     String?
  span_id      String?
  timestamp    DateTime @default(now())

  execution WorkflowExecution @relation(fields: [execution_id], references: [id], onDelete: Cascade)

  @@index([execution_id])
  @@index([timestamp])
  @@index([level])
  @@index([trace_id])
  @@map("workflow_execution_logs")
  @@schema("public")
}

model WorkflowWebhook {
  id          String  @id @default(uuid())
  workflow_id String
  webhook_key String  @unique
  name        String
  description String? @db.Text

  // Security
  secret       String?
  allowed_ips  String[] @default([])
  require_auth Boolean  @default(false)

  // Configuration
  method        String @default("POST")
  response_mode String @default("async") // async, sync
  timeout_ms    Int    @default(30000)

  // Rate limiting
  rate_limit_per_minute Int @default(60)

  // Statistics
  total_calls    Int       @default(0)
  last_called_at DateTime?

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  workflow Workflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)

  @@index([workflow_id])
  @@map("workflow_webhooks")
  @@schema("public")
}

model WorkflowSchedule {
  id          String  @id @default(uuid())
  workflow_id String
  name        String
  description String? @db.Text

  // Schedule configuration
  cron_expression String
  timezone        String @default("UTC")
  input_template  Json   @default("{}")

  // Status
  is_active       Boolean   @default(true)
  next_run_at     DateTime?
  last_run_at     DateTime?
  last_run_status String?

  // Statistics
  total_runs      Int @default(0)
  successful_runs Int @default(0)
  failed_runs     Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  workflow Workflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)

  @@index([workflow_id])
  @@index([next_run_at])
  @@map("workflow_schedules")
  @@schema("public")
}

model WorkflowTest {
  id          String  @id @default(uuid())
  workflow_id String
  name        String
  description String? @db.Text

  // Test configuration
  input              Json
  mocks              Json   @default("{}")
  assertions         Json   @default("[]")
  expected_output    Json?
  expected_nodes     String[] @default([])
  expected_max_ms    Int?

  // Last run
  last_run_at        DateTime?
  last_run_passed    Boolean?
  last_run_error     String?   @db.Text
  last_run_duration  Int?

  is_active  Boolean  @default(true)
  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  workflow Workflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  creator  User?    @relation(fields: [created_by], references: [id])

  @@index([workflow_id])
  @@map("workflow_tests")
  @@schema("public")
}

// ============================================================================
// USER GROUPS & CHARGEBACK (NEW)
// ============================================================================

model UserGroup {
  id                    String  @id @default(uuid())
  name                  String  @unique
  display_name          String
  description           String? @db.Text
  parent_group_id       String?
  cost_center           String?
  billing_contact_email String?
  metadata              Json    @default("{}")
  is_active             Boolean @default(true)
  created_by            String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  // Relations
  parent_group    UserGroup?              @relation("GroupHierarchy", fields: [parent_group_id], references: [id])
  child_groups    UserGroup[]             @relation("GroupHierarchy")
  memberships     UserGroupMembership[]
  cost_budgets    CostBudget[]
  chargeback_reports ChargebackReport[]
  workflows       Workflow[]
  workflow_executions WorkflowExecution[]
  workflow_secrets WorkflowSecret[]       @relation("GroupSecrets")
  rate_limits     RateLimit[]
  token_usage     TokenUsage[]            @relation("GroupTokenUsage")

  @@index([name])
  @@index([parent_group_id])
  @@index([cost_center])
  @@map("user_groups")
  @@schema("admin")
}

model UserGroupMembership {
  id         String   @id @default(uuid())
  user_id    String
  group_id   String
  role       String   @default("member") // member, admin, billing
  is_primary Boolean  @default(false)
  joined_at  DateTime @default(now())
  added_by   String?

  user  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  group UserGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  adder User?     @relation("MembershipAdder", fields: [added_by], references: [id])

  @@unique([user_id, group_id])
  @@index([user_id])
  @@index([group_id])
  @@map("user_group_memberships")
  @@schema("admin")
}

model CostBudget {
  id          String  @id @default(uuid())
  name        String
  budget_type String // user, group, global
  user_id     String?
  group_id    String?

  // Budget amounts (USD)
  daily_limit   Decimal? @db.Decimal(10, 2)
  weekly_limit  Decimal? @db.Decimal(10, 2)
  monthly_limit Decimal  @db.Decimal(10, 2)
  annual_limit  Decimal? @db.Decimal(10, 2)

  // Alert thresholds
  alert_threshold_50  Boolean @default(true)
  alert_threshold_75  Boolean @default(true)
  alert_threshold_90  Boolean @default(true)
  alert_threshold_100 Boolean @default(true)

  // Action on limit
  action_on_limit   String  @default("warn") // warn, throttle, block
  throttle_to_model String?

  // Notifications
  notify_emails        String[] @default([])
  notify_slack_channel String?

  // Period tracking
  current_period_start DateTime @default(now())
  current_spend        Decimal  @default(0) @db.Decimal(10, 6)

  is_active  Boolean  @default(true)
  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User?      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  group   UserGroup? @relation(fields: [group_id], references: [id], onDelete: Cascade)
  creator User?      @relation("BudgetCreator", fields: [created_by], references: [id])

  @@index([user_id])
  @@index([group_id])
  @@index([budget_type])
  @@map("cost_budgets")
  @@schema("admin")
}

model ChargebackReport {
  id            String  @id @default(uuid())
  report_period String // YYYY-MM format
  group_id      String?
  user_id       String?
  cost_center   String?

  // Token metrics
  total_input_tokens    BigInt  @default(0)
  total_output_tokens   BigInt  @default(0)
  total_cached_tokens   BigInt  @default(0)
  total_thinking_tokens BigInt  @default(0)

  // Cost breakdowns
  cost_by_provider Json @default("{}")
  cost_by_model    Json @default("{}")

  // Total costs
  total_llm_cost     Decimal @default(0) @db.Decimal(10, 6)
  total_mcp_cost     Decimal @default(0) @db.Decimal(10, 6)
  total_compute_cost Decimal @default(0) @db.Decimal(10, 6)
  total_storage_cost Decimal @default(0) @db.Decimal(10, 6)
  total_cost         Decimal @default(0) @db.Decimal(10, 6)

  // Usage metrics
  total_requests            Int @default(0)
  total_sessions            Int @default(0)
  total_workflow_executions Int @default(0)
  total_code_executions     Int @default(0)

  // Status
  status        String    @default("draft") // draft, finalized, exported, paid
  finalized_at  DateTime?
  exported_at   DateTime?
  export_format String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  group UserGroup? @relation(fields: [group_id], references: [id])
  user  User?      @relation(fields: [user_id], references: [id])

  @@unique([report_period, group_id, user_id])
  @@index([report_period])
  @@index([group_id])
  @@index([user_id])
  @@map("chargeback_reports")
  @@schema("admin")
}

// ============================================================================
// MODEL PRICING - Accurate per-model cost calculation (NEW)
// ============================================================================

model ModelPricing {
  id                      String    @id @default(uuid())
  provider                String // anthropic, openai, google, azure, ollama, aws-bedrock
  model                   String
  model_family            String?
  input_cost_per_1k       Decimal   @db.Decimal(10, 6)
  output_cost_per_1k      Decimal   @db.Decimal(10, 6)
  cached_input_cost_per_1k Decimal? @db.Decimal(10, 6)
  thinking_cost_per_1k    Decimal?  @db.Decimal(10, 6)
  image_input_cost        Decimal?  @db.Decimal(10, 6)
  effective_date          DateTime  @default(now())
  end_date                DateTime?
  notes                   String?   @db.Text
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@unique([provider, model, effective_date])
  @@index([provider, model])
  @@index([effective_date])
  @@map("model_pricing")
  @@schema("admin")
}

// ============================================================================
// SECRETS MANAGEMENT WITH ESO (NEW)
// ============================================================================

model WorkflowSecret {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  scope       String // global, group, workflow
  group_id    String?
  workflow_id String?

  // ESO Configuration
  eso_enabled          Boolean @default(true)
  eso_secret_store     String  @default("openagentic-secrets")
  eso_secret_store_kind String @default("ClusterSecretStore")
  eso_remote_ref       Json

  // K8s reference
  k8s_secret_name      String?
  k8s_secret_namespace String  @default("openagentic")
  k8s_secret_key       String  @default("value")

  // Fallback (dev only)
  encrypted_value   String?
  encryption_key_id String?

  // Metadata
  version           Int       @default(1)
  last_rotated_at   DateTime?
  expires_at        DateTime?
  rotation_schedule String?

  // Access control
  allowed_node_types String[] @default([])
  allowed_users      String[] @default([])
  allowed_groups     String[] @default([])

  // Audit
  last_accessed_at DateTime?
  access_count     Int       @default(0)

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  group    UserGroup? @relation("GroupSecrets", fields: [group_id], references: [id], onDelete: Cascade)
  workflow Workflow?  @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  creator  User?      @relation(fields: [created_by], references: [id])
  data_sources    DataSource[]

  @@unique([name, scope, group_id, workflow_id])
  @@index([scope])
  @@index([group_id])
  @@index([workflow_id])
  @@index([k8s_secret_name, k8s_secret_namespace])
  @@map("workflow_secrets")
  @@schema("admin")
}

// ─── Data Sources (Reusable connections for flows) ─────────────────────────
model DataSource {
  id              String   @id @default(uuid())
  name            String
  description     String?  @db.Text
  type            String   // postgres, mysql, rest_api, s3, milvus, redis, graphql
  connection_config Json   // { host, port, database, path, headers, etc. }
  secret_id       String?  // FK to WorkflowSecret for credentials
  schema_cache    Json?    // Cached schema: { tables: [{ name, columns: [{ name, type }] }] }
  schema_probed_at DateTime?
  status          String   @default("untested") // untested, connected, failed
  status_message  String?
  created_by      String
  is_shared       Boolean  @default(false)
  tags            String[] @default([])
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  secret          WorkflowSecret? @relation(fields: [secret_id], references: [id])

  @@unique([name, created_by])
  @@index([type])
  @@index([created_by])
  @@map("data_sources")
  @@schema("public")
}

model ESOSecretStore {
  id        String @id @default(uuid())
  name      String @unique
  kind      String @default("ClusterSecretStore")
  provider  String // aws, azure, gcp, vault, kubernetes

  provider_config Json

  // Health
  last_health_check DateTime?
  health_status     String    @default("unknown")
  health_message    String?   @db.Text

  // Usage
  secrets_count Int       @default(0)
  last_sync_at  DateTime?

  is_default Boolean  @default(false)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([provider])
  @@index([is_default])
  @@map("eso_secret_stores")
  @@schema("admin")
}

// ============================================================================
// RATE LIMITING (NEW)
// ============================================================================

model RateLimit {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  scope       String // global, group, user
  group_id    String?
  user_id     String?

  // Request limits
  requests_per_minute Int @default(60)
  requests_per_hour   Int @default(1000)
  requests_per_day    Int @default(10000)

  // Token limits
  tokens_per_minute Int @default(100000)
  tokens_per_hour   Int @default(1000000)
  tokens_per_day    Int @default(10000000)

  // Workflow limits
  workflow_executions_per_hour Int @default(100)
  concurrent_workflows         Int @default(10)

  // Code execution limits
  code_executions_per_hour     Int @default(50)
  code_execution_timeout_sec   Int @default(300)

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  group UserGroup? @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user  User?      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([scope])
  @@index([group_id])
  @@index([user_id])
  @@map("rate_limits")
  @@schema("admin")
}


// ============================================================================
// CREDENTIAL AUDIT LOG - Tracks admin CRUD on LLM providers, MCP servers, API keys
// ============================================================================

model CredentialAuditLog {
  id          String   @id @default(uuid())
  user_id     String
  user_email  String?
  action      String   // "create", "update", "delete", "view", "enable", "disable"
  entity_type String   // "llm_provider", "mcp_server", "api_key"
  entity_id   String
  entity_name String?
  changes     Json?    // { field: { old: x, new: y } } for updates
  ip_address  String?
  user_agent  String?  @db.Text
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([entity_type])
  @@index([entity_id])
  @@index([action])
  @@index([created_at])
  @@map("credential_audit_log")
  @@schema("admin")
}

// ============================================================================
// AGENT MEMORY - Persistent memory for agents across sessions
// ============================================================================

model AgentMemory {
  id         String   @id @default(uuid())
  user_id    String
  category   String   // e.g. "preference", "fact", "workflow", "cloud"
  key        String
  value      String   @db.Text
  confidence Float    @default(1.0)
  ttl_hours  Int?     // optional expiry
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id, category])
  @@index([user_id, key])
  @@map("agent_memories")
  @@schema("public")
}

// ============================================================================
// Rate Limit Violations — persisted enforcement data
// ============================================================================

model RateLimitViolation {
  id             String   @id @default(uuid())
  user_id        String?
  user_email     String?
  violation_type String   // requests_per_minute, requests_per_hour, requests_per_day, tokens_per_day
  limit_value    Int
  actual_value   Int
  tier_name      String?  // which tier was in effect
  endpoint       String?  // which endpoint triggered the violation
  ip_address     String?
  metadata       Json?    @db.JsonB
  created_at     DateTime @default(now())

  @@index([user_id])
  @@index([violation_type])
  @@index([created_at])
  @@index([tier_name])
  @@map("rate_limit_violations")
  @@schema("admin")
}

// ============================================================================
// MCP Tool-Level Access Policies — per-tool granularity
// ============================================================================

model MCPToolAccessPolicy {
  id               String   @id @default(uuid())
  server_id        String   // MCP server ID
  tool_name        String   // specific tool name (or '*' for all tools)
  azure_group_id   String?  // Azure AD group (null = applies to all)
  user_id          String?  // specific user override (null = group-level)
  access_type      String   // 'allow' | 'deny'
  is_enabled       Boolean  @default(true)
  priority         Int      @default(1000) // Lower = higher priority
  reason           String?  @db.Text
  require_approval Boolean  @default(false) // require human approval before execution
  created_by       String?
  updated_by       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([server_id])
  @@index([tool_name])
  @@index([azure_group_id])
  @@index([user_id])
  @@index([server_id, tool_name])
  @@index([priority])
  @@map("mcp_tool_access_policies")
  @@schema("public")
}


model IdempotencyKey {
  idempotency_key String   @id
  execution_id    String
  result          Json
  expires_at      DateTime
  created_at      DateTime @default(now())

  @@index([expires_at])
  @@map("idempotency_keys")
  @@schema("public")
}
