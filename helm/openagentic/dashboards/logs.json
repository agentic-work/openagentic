  "panels": [
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "description": "Live logs from namespace with filtering",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false,
        "showCommonLabels": false, "showLabels": true, "showTime": true,
        "sortOrder": "Descending", "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{namespace=\"{{ .Release.Namespace }}\", pod=~\"$pod\", container=~\"$container\"} |~ \"$search\"",
          "queryType": "range", "refId": "A"
        }
      ],
      "title": "Live Logs Stream", "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "description": "Log volume over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 100, "stacking": { "group": "A", "mode": "normal" }, "thresholdsStyle": { "mode": "off" } },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 2,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (pod) (rate({namespace=\"{{ .Release.Namespace }}\"} |~ \"$search\" [$__interval]))",
          "legendFormat": "{{pod}}", "queryType": "range", "refId": "A"
        }
      ],
      "title": "Log Volume by Pod", "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "description": "Top 10 pods by log volume",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 5000 } ] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 3,
      "options": { "displayMode": "lcd", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (pod) (rate({namespace=\"{{ .Release.Namespace }}\", pod=~\"$pod\"} |~ \"$search\" [5m]))",
          "queryType": "range", "refId": "A"
        }
      ],
      "title": "Top Pods by Log Volume", "type": "bargauge"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "description": "Error logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 4,
      "options": {
        "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false,
        "showCommonLabels": false, "showLabels": true, "showTime": true,
        "sortOrder": "Descending", "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{namespace=\"{{ .Release.Namespace }}\"} |~ \"(?i)(error|fail|exception|panic|fatal)\"",
          "queryType": "range", "refId": "A"
        }
      ],
      "title": "Error Logs", "type": "logs"
    }
  ],
