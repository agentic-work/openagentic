      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "histogram_quantile(0.95, sum(rate(openagentic_proxy_agent_execution_duration_seconds_bucket{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[5m])) by (le, tool))", "legendFormat": "{{tool}} p95", "refId": "A" }
      ]
    },
    {
