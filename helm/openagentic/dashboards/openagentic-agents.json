  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1, "title": "Execution Overview", "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false, "panels": []
    },
    {
      "id": 2, "title": "Active Executions", "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "min": 0, "max": 50, "thresholds": { "steps": [ { "value": null, "color": "green" }, { "value": 20, "color": "yellow" }, { "value": 40, "color": "red" } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(openagentic_proxy_active_executions{kubernetes_namespace=\"{{ .Release.Namespace }}\"}) or vector(0)", "legendFormat": "active", "refId": "A" }
      ]
    },
    {
      "id": 3, "title": "Total Executions (24h)", "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "value": null, "color": "blue" } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(increase(openagentic_proxy_agent_executions_total{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[24h])) or vector(0)", "legendFormat": "total", "refId": "A" }
      ]
    },
    {
      "id": 4, "title": "Error Rate", "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [ { "value": null, "color": "green" }, { "value": 0.05, "color": "yellow" }, { "value": 0.1, "color": "red" } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(openagentic_proxy_agent_executions_total{kubernetes_namespace=\"{{ .Release.Namespace }}\", status=\"error\"}[5m])) / sum(rate(openagentic_proxy_agent_executions_total{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[5m])) or vector(0)", "legendFormat": "error %", "refId": "A" }
      ]
    },
    {
      "id": 5, "title": "Avg Tool Calls per Execution", "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "value": null, "color": "purple" } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(openagentic_proxy_tool_calls_total{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[5m])) / sum(rate(openagentic_proxy_agent_executions_total{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[5m])) or vector(0)", "legendFormat": "tools/exec", "refId": "A" }
      ]
    },
    {
      "id": 10, "title": "Executions by Pattern", "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }, "collapsed": false, "panels": []
    },
    {
      "id": 11, "title": "Execution Rate by Pattern", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(openagentic_proxy_agent_executions_total{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[5m])) by (pattern)", "legendFormat": "{{pattern}}", "refId": "A" }
      ]
    },
    {
      "id": 12, "title": "Execution Duration by Pattern (p95)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "histogram_quantile(0.95, sum(rate(openagentic_proxy_agent_execution_duration_seconds_bucket{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[5m])) by (le, pattern))", "legendFormat": "{{pattern}} p95", "refId": "A" }
      ]
    },
    {
      "id": 13, "title": "Error Rate by Pattern", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(openagentic_proxy_agent_executions_total{kubernetes_namespace=\"{{ .Release.Namespace }}\", status=\"error\"}[5m])) by (pattern)", "legendFormat": "{{pattern}} errors", "refId": "A" }
      ]
    },
    {
      "id": 14, "title": "Executions by Pattern (24h)", "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "value": null, "color": "blue" }, { "value": 50, "color": "green" }, { "value": 200, "color": "yellow" } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(increase(openagentic_proxy_agent_executions_total{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[24h])) by (pattern)", "legendFormat": "{{pattern}}", "refId": "A" }
      ]
    },
    {
      "id": 20, "title": "Tool Calls & Cost", "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }, "collapsed": false, "panels": []
    },
    {
      "id": 21, "title": "Tool Call Rate", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(openagentic_proxy_tool_calls_total{kubernetes_namespace=\"{{ .Release.Namespace }}\"}[5m])) by (tool)", "legendFormat": "{{tool}}", "refId": "A" }
      ]
    },
    {
      "id": 22, "title": "Execution Duration p95", "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
