# Caddyfile for OpenAgentic - Static Certificate (NO ACME)
# Uses pre-existing wildcard certificate from K8s cert-manager
# Certificate is managed by cert-manager with Let's Encrypt DNS-01 challenges
# Caddy does NOT obtain or renew certificates - it only uses the static files

{
	# DISABLE automatic HTTPS - we provide our own certs
	auto_https off

	# No email needed - we don't use ACME
	# No acme_ca - we don't use ACME
}

# Local testing - HTTP only (no HTTPS)
:8080 {
	handle /api/* {
		reverse_proxy openagentic-api:8000
	}
	handle /v1/* {
		reverse_proxy openagentic-api:8000
	}
	handle /ws/* {
		reverse_proxy openagentic-api:8000
	}
	handle /flowise/* {
		uri strip_prefix /flowise
		reverse_proxy openagentic-flowise:3000
	}
	handle /mcp/* {
		uri strip_prefix /mcp
		reverse_proxy openagentic-mcp-proxy:8080
	}
	# OpenAgentic Manager
	handle /openagentic/* {
		uri strip_prefix /openagentic
		reverse_proxy openagentic-manager:3050
	}
	# Code Server - proxies to VS Code instances (ports 3100-3199)
	# For EXECUTION_MODE=local: code-server runs in openagentic-manager
	# For EXECUTION_MODE=exec-container: code-server runs in openagentic-exec
	# Default to openagentic-manager for local development
	@localcs3100 path /code-server/3100 /code-server/3100/*
	handle @localcs3100 {
		uri strip_prefix /code-server/3100
		reverse_proxy openagentic-manager:3100
	}
	@localcs3101 path /code-server/3101 /code-server/3101/*
	handle @localcs3101 {
		uri strip_prefix /code-server/3101
		reverse_proxy openagentic-manager:3101
	}
	@localcs3102 path /code-server/3102 /code-server/3102/*
	handle @localcs3102 {
		uri strip_prefix /code-server/3102
		reverse_proxy openagentic-manager:3102
	}
	@localcs3103 path /code-server/3103 /code-server/3103/*
	handle @localcs3103 {
		uri strip_prefix /code-server/3103
		reverse_proxy openagentic-manager:3103
	}
	@localcs3104 path /code-server/3104 /code-server/3104/*
	handle @localcs3104 {
		uri strip_prefix /code-server/3104
		reverse_proxy openagentic-manager:3104
	}
	@localcs3105 path /code-server/3105 /code-server/3105/*
	handle @localcs3105 {
		uri strip_prefix /code-server/3105
		reverse_proxy openagentic-manager:3105
	}
	handle {
		reverse_proxy openagentic-ui:80
	}
}

# UAT Dashboard - internal testing interface
# Uses same wildcard certificate for uat.openagentic.io
uat.openagentic.io {
	# Use static wildcard certificate - NO ACME
	tls /certs/wildcard.crt /certs/wildcard.key

	# Proxy all requests to UAT dashboard on K8s
	# Note: UAT dashboard runs in K8s, accessible via NodePort or host network
	reverse_proxy 10.2.10.36:30333
}

# Production HTTPS - uses static wildcard certificate
# Certificate: Let's Encrypt production (R12), valid for *.openagentic.io
# Managed by: K8s cert-manager (DNS-01 challenge via Google Cloud DNS)
# Location: /certs/wildcard.crt and /certs/wildcard.key
chat-dev.openagentic.io, mac.openagentic.io {
	# Use static wildcard certificate - NO ACME
	tls /certs/wildcard.crt /certs/wildcard.key

	# API routes
	handle /api/* {
		reverse_proxy openagentic-api:8000
	}

	handle /v1/* {
		reverse_proxy openagentic-api:8000
	}

	# WebSocket
	handle /ws/* {
		reverse_proxy openagentic-api:8000
	}

	# Flowise
	handle /flowise/* {
		uri strip_prefix /flowise
		reverse_proxy openagentic-flowise:3000
	}

	# OpenAgentic Manager
	handle /openagentic/* {
		uri strip_prefix /openagentic
		reverse_proxy openagentic-manager:3050
	}

	# Code Server - proxies to individual VS Code instances
	# URL format: /code-server/{port}/?folder=/workspaces/...
	# For EXECUTION_MODE=local: code-server runs in openagentic-manager
	# For EXECUTION_MODE=exec-container: code-server runs in openagentic-exec
	# Default to openagentic-manager for local development
	@codeserver3100 path /code-server/3100 /code-server/3100/*
	handle @codeserver3100 {
		uri strip_prefix /code-server/3100
		reverse_proxy openagentic-manager:3100 {
			header_up Host {upstream_hostport}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}
	@codeserver3101 path /code-server/3101 /code-server/3101/*
	handle @codeserver3101 {
		uri strip_prefix /code-server/3101
		reverse_proxy openagentic-manager:3101 {
			header_up Host {upstream_hostport}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}
	@codeserver3102 path /code-server/3102 /code-server/3102/*
	handle @codeserver3102 {
		uri strip_prefix /code-server/3102
		reverse_proxy openagentic-manager:3102 {
			header_up Host {upstream_hostport}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}
	@codeserver3103 path /code-server/3103 /code-server/3103/*
	handle @codeserver3103 {
		uri strip_prefix /code-server/3103
		reverse_proxy openagentic-manager:3103 {
			header_up Host {upstream_hostport}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}
	@codeserver3104 path /code-server/3104 /code-server/3104/*
	handle @codeserver3104 {
		uri strip_prefix /code-server/3104
		reverse_proxy openagentic-manager:3104 {
			header_up Host {upstream_hostport}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}
	@codeserver3105 path /code-server/3105 /code-server/3105/*
	handle @codeserver3105 {
		uri strip_prefix /code-server/3105
		reverse_proxy openagentic-manager:3105 {
			header_up Host {upstream_hostport}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}

	# MCP Proxy
	handle /mcp/* {
		uri strip_prefix /mcp
		reverse_proxy openagentic-mcp-proxy:8080
	}

	# Default to UI
	handle {
		reverse_proxy openagentic-ui:80
	}
}
