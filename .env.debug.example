# ===========================================
# OpenAgenticChat Debug Environment Variables
# ===========================================
# Copy this to .env and set values as needed
# Most debug options default to false for production

# ===========================================
# LOG LEVEL
# ===========================================
LOG_LEVEL=debug  # Options: fatal, error, warn, info, debug, trace

# ===========================================
# RATE LIMITING PREVENTION (Azure AI Foundry)
# ===========================================
# CRITICAL: Set these to true in production to avoid rate limits

# Disable model discovery on startup (prevents API calls)
DISABLE_MODEL_DISCOVERY=true

# Disable capability testing (prevents test API calls)
DISABLE_MODEL_TESTING=true

# Disable periodic health checks (reduces API calls)
DISABLE_MODEL_HEALTH_CHECK=false

# Health check interval (default 5 minutes = 300000ms)
MODEL_HEALTH_CHECK_INTERVAL_MS=300000

# Model discovery cache TTL (default 24 hours = 86400000ms)
MODEL_DISCOVERY_CACHE_TTL_MS=86400000

# ===========================================
# SSE & STREAMING DEBUGGING
# ===========================================
# Enable detailed SSE streaming logs
# Shows: TTFT (Time to First Token), chunk counts, timing
SSE_DEBUG=true

# ===========================================
# PIPELINE & THINKING DEBUGGING
# ===========================================
# Enable verbose pipeline stage logging
DEBUG_PIPELINE=true

# Enable verbose MCP tool execution logging
DEBUG_MCP=true

# Enable detailed thinking event logging
DEBUG_THINKING=true

# Log full LLM request/response payloads
# WARNING: Very verbose, use only for debugging specific issues
DEBUG_LLM_REQUESTS=false

# ===========================================
# UI DEBUGGING (VITE_ prefix required)
# ===========================================
# Note: These require UI rebuild to take effect

# Enable SSE debug logging in browser console
DEBUG_SSE=true

# Enable thinking box debug logging
DEBUG_THINKING=true

# Enable pipeline state debug logging
DEBUG_PIPELINE=true

# ===========================================
# USAGE
# ===========================================
# To enable all debugging:
#   cp .env.debug.example .env
#   docker compose up -d
#
# To enable specific debugging in running container:
#   SSE_DEBUG=true docker compose up -d openagenticchat-api
#
# View debug logs:
#   docker logs -f openagenticchat-api 2>&1 | grep -E "\[SSE-DEBUG\]|\[PIPELINE\]|\[MCP\]|\[THINKING\]"
