# Test Environment Configuration for Docker Compose
# Use: TEST_ENV=docker npm run test:e2e

TEST_ENV=docker
TEST_API_URL=http://localhost:8000
TEST_UI_URL=http://localhost:80
TEST_MCP_URL=http://localhost:8090
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openagentic
TEST_REDIS_URL=redis://localhost:16379

# Test credentials (create these in your local environment)
TEST_API_KEY=awc_test_key_replace_with_real_key
TEST_USER_EMAIL=test@openagentic.io
TEST_USER_PASSWORD=test_password

# Flowise
TEST_FLOWISE_URL=http://localhost:3000

# Ollama
TEST_OLLAMA_URL=http://localhost:11434

# Timeouts
TEST_TIMEOUT=60000
TEST_SSE_TIMEOUT=120000
