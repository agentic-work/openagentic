loyment, k8s_scale_deployment, k8s_cluster_health, incident_resolve, incident_escalate, incident_link_runbook, incident_update_status"},"result":null,"error":"connect ECONNREFUSED 10.43.224.106:8080","status":"failed","startTime":1771625358579,"endTime":1771625359153,"duration":574,"timestamp":"2026-02-20T22:09:19.153Z"}],"tokenUsage":{"prompt_tokens":0,"completion_tokens":138,"total_tokens":138},"model":"us.anthropic.claude-opus-4-6-v1","source":"database","confirmed":true,"final":true}

