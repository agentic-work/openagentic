event: content_block_stop
data: {"index":1,"blockType":"tool_use","finalContent":"{\"description\": \"Create a SecurityTriageAgent that acts as the first responder for security incidents. It monitors Prometheus alerts for anomalies, searches Loki error logs for correlated failures, checks for existing open incidents to avoid duplicates, and creates new incidents with proper severity classification (SEV1-SEV4). The agent runs in a continuous loop: poll alerts → correlate with logs → deduplicate → classify severity → create incident → hand off to ForensicsAgent. Tools needed: incident_create, incident_list, loki_search_errors, prometheus_alerts. Framework: LangGraph StateGraph with conditional routing based on alert severity.\", \"framework\": \"langgraph\", \"tools\": \"incident_create,incident_list,loki_search_errors,prometheus_alerts\"}","toolId":"toolu_bdrk_015B8k2rV7eecdAJ7dPCmXBL","toolName":"design_custom_agent"}

