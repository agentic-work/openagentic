data: {"messageId":"ERxL5BrlyQH_liBodb-k3","role":"tool","content":"{\n  \"content\": [\n    {\n      \"type\": \"text\",\n      \"text\": \"{\\\"success\\\":true,\\\"cached\\\":false,\\\"url\\\":\\\"https://www.nist.gov/itl/ai-risk-management-framework\\\",\\\"title\\\":\\\"AI Risk Management Framework | NIST\\\",\\\"content\\\":\\\"[![Circular design includes elements of the AI Risk Management Framework: Govern, Measure, Manage, Map.](/sites/default/files/styles/thumbnail/public/images/2023/01/25/RMF-redesign-rounded-other_graphics-04.png?itok=q6XNzk9H)](/news-events/news/2023/01/nist-risk-management-framework-aims-improve-trustworthiness-artificial)\\\\n\\\\nNew guidance seeks to cultivate trust in AI technologies and promote AI innovation while mitigating risk.\\\",\\\"content_length\\\":431,\\\"links\\\":[{\\\"text\\\":\\\"Skip to main content\\\",\\\"url\\\":\\\"https://www.nist.gov/itl/ai-risk-management-framework#main-content\\\"},{\\\"text\\\":\\\"Information Technology Laboratory\\\",\\\"url\\\":\\\"https://www.nist.gov/itl\\\"},{\\\"text\\\":\\\"Download the AI RMF 1.0\\\",\\\"url\\\":\\\"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.pdf\\\"},{\\\"text\\\":\\\"View the AI RMF Playbook\\\",\\\"url\\\":\\\"https://airc.nist.gov/airmf-resources/playbook/\\\"},{\\\"text\\\":\\\"Visit the AI Resource Center\\\",\\\"url\\\":\\\"https://airc.nist.gov/\\\"},{\\\"text\\\":\\\"NIST AI Risk Management Framework (AI RMF)\\\",\\\"url\\\":\\\"https://doi.org/10.6028/NIST.AI.100-1\\\"},{\\\"text\\\":\\\"workshops\\\",\\\"url\\\":\\\"https://www.nist.gov/artificial-intelligence/nist-ai-engagement\\\"},{\\\"text\\\":\\\"Fact Sheet\\\",\\\"url\\\":\\\"https://www.nist.gov/document/about-nist-ai-rmf\\\"},{\\\"text\\\":\\\"NIST AI RMF Playbook\\\",\\\"url\\\":\\\"https://airc.nist.gov/AI_RMF_Knowledge_Base/Playbook\\\"},{\\\"text\\\":\\\"AI RMF Roadmap\\\",\\\"url\\\":\\\"https://www.nist.gov/itl/ai-risk-management-framework/roadmap-nist-artificial-intelligence-risk-management-framework-ai\\\"},{\\\"text\\\":\\\"AI RMF Crosswalk\\\",\\\"url\\\":\\\"https://www.nist.gov/itl/ai-risk-management-framework/crosswalks-nist-artificial-intelligence-risk-management-framework\\\"},{\\\"text\\\":\\\"Perspectives\\\",\\\"url\\\":\\\"https://www.nist.gov/itl/ai-risk-management-framework/perspectives-about-nist-artificial-intelligence-risk-management\\\"},{\\\"text\\\":\\\"Trustworthy and Responsible AI Resource Center\\\",\\\"url\\\":\\\"https://airc.nist.gov/Home\\\"},{\\\"text\\\":\\\"AIRC’s Use Case page\\\",\\\"url\\\":\\\"https://airc.nist.gov/Usecases\\\"},{\\\"text\\\":\\\"NIST-AI-600-1, Artificial Intelligence Risk Management Framework: Generative Artificial Intelligence\\\",\\\"url\\\":\\\"https://doi.org/10.6028/NIST.AI.600-1\\\"},{\\\"text\\\":\\\"AI RMF Development\\\",\\\"url\\\":\\\"https://www.nist.gov/itl/ai-risk-management-framework/ai-rmf-development\\\"},{\\\"text\\\":\\\"NIST AI Risk Management Framework\\\",\\\"url\\\":\\\"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.ara.pdf\\\"},{\\\"text\\\":\\\"NIST AI Risk Management Framework\\\",\\\"url\\\":\\\"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.jpn.pdf\\\"},{\\\"text\\\":\\\"Second draft of the AI Risk Management Framework\\\",\\\"url\\\":\\\"https://www.nist.gov/document/ai-risk-management-framework-2nd-draft\\\"},{\\\"text\\\":\\\"Initial draft of the AI Risk Management Framework\\\",\\\"url\\\":\\\"https://www.nist.gov/document/ai-risk-management-framework-initial-draft\\\"},{\\\"text\\\":\\\"Concept paper to help guide development of the AI Risk Management Framework\\\",\\\"url\\\":\\\"https://www.nist.gov/document/airmfconceptpaper\\\"},{\\\"text\\\":\\\"Brief summary\\\",\\\"url\\\":\\\"https://www.nist.gov/document/summary-analysis-responses-nist-artificial-intelligence-risk-management-framework-ai-rmf\\\"},{\\\"text\\\":\\\"responses\\\",\\\"url\\\":\\\"https://www.nist.gov/itl/ai-risk-management-framework/comments-received-rfi-artificial-intelligence-risk-management\\\"},{\\\"text\\\":\\\"Draft -Taxonomy of AI Risk\\\",\\\"url\\\":\\\"https://www.nist.gov/document/draft-taxonomy-ai-risk-october-15-2021\\\"},{\\\"text\\\":\\\"AI Risk Management Framework Request for Information\\\",\\\"url\\\":\\\"https://www.federalregister.gov/documents/2021/07/29/2021-16176/artificial-intelligence-risk-management-framework\\\"},{\\\"text\\\":\\\"Was this page helpful?\\\",\\\"url\\\":\\\"https://www.nist.gov/webform/page_feedback?page=https://www.nist.gov/itl/ai-risk-management-framework&page_title=AI Risk Management Framework&source_entity_type=node&source_entity_id=1674601\\\"}]}\"\n    }\n  ],\n  \"structuredContent\": {\n    \"success\": true,\n    \"cached\": false,\n    \"url\": \"https://www.nist.gov/itl/ai-risk-management-framework\",\n    \"title\": \"AI Risk Management Framework | NIST\",\n    \"content\": \"[![Circular design includes elements of the AI Risk Management Framework: Govern, Measure, Manage, Map.](/sites/default/files/styles/thumbnail/public/images/2023/01/25/RMF-redesign-rounded-other_graphics-04.png?itok=q6XNzk9H)](/news-events/news/2023/01/nist-risk-management-framework-aims-improve-trustworthiness-artificial)\\n\\nNew guidance seeks to cultivate trust in AI technologies and promote AI innovation while mitigating risk.\",\n    \"content_length\": 431,\n    \"links\": [\n      {\n        \"text\": \"Skip to main content\",\n        \"url\": \"https://www.nist.gov/itl/ai-risk-management-framework#main-content\"\n      },\n      {\n        \"text\": \"Information Technology Laboratory\",\n        \"url\": \"https://www.nist.gov/itl\"\n      },\n      {\n        \"text\": \"Download the AI RMF 1.0\",\n        \"url\": \"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.pdf\"\n      },\n      {\n        \"text\": \"View the AI RMF Playbook\",\n        \"url\": \"https://airc.nist.gov/airmf-resources/playbook/\"\n      },\n      {\n        \"text\": \"Visit the AI Resource Center\",\n        \"url\": \"https://airc.nist.gov/\"\n      },\n      {\n        \"text\": \"NIST AI Risk Management Framework (AI RMF)\",\n        \"url\": \"https://doi.org/10.6028/NIST.AI.100-1\"\n      },\n      {\n        \"text\": \"workshops\",\n        \"url\": \"https://www.nist.gov/artificial-intelligence/nist-ai-engagement\"\n      },\n      {\n        \"text\": \"Fact Sheet\",\n        \"url\": \"https://www.nist.gov/document/about-nist-ai-rmf\"\n      },\n      {\n        \"text\": \"NIST AI RMF Playbook\",\n        \"url\": \"https://airc.nist.gov/AI_RMF_Knowledge_Base/Playbook\"\n      },\n      {\n        \"text\": \"AI RMF Roadmap\",\n        \"url\": \"https://www.nist.gov/itl/ai-risk-management-framework/roadmap-nist-artificial-intelligence-risk-management-framework-ai\"\n      },\n      {\n        \"text\": \"AI RMF Crosswalk\",\n        \"url\": \"https://www.nist.gov/itl/ai-risk-management-framework/crosswalks-nist-artificial-intelligence-risk-management-framework\"\n      },\n      {\n        \"text\": \"Perspectives\",\n        \"url\": \"https://www.nist.gov/itl/ai-risk-management-framework/perspectives-about-nist-artificial-intelligence-risk-management\"\n      },\n      {\n        \"text\": \"Trustworthy and Responsible AI Resource Center\",\n        \"url\": \"https://airc.nist.gov/Home\"\n      },\n      {\n        \"text\": \"AIRC’s Use Case page\",\n        \"url\": \"https://airc.nist.gov/Usecases\"\n      },\n      {\n        \"text\": \"NIST-AI-600-1, Artificial Intelligence Risk Management Framework: Generative Artificial Intelligence\",\n        \"url\": \"https://doi.org/10.6028/NIST.AI.600-1\"\n      },\n      {\n        \"text\": \"AI RMF Development\",\n        \"url\": \"https://www.nist.gov/itl/ai-risk-management-framework/ai-rmf-development\"\n      },\n      {\n        \"text\": \"NIST AI Risk Management Framework\",\n        \"url\": \"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.ara.pdf\"\n      },\n      {\n        \"text\": \"NIST AI Risk Management Framework\",\n        \"url\": \"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.jpn.pdf\"\n      },\n      {\n        \"text\": \"Second draft of the AI Risk Management Framework\",\n        \"url\": \"https://www.nist.gov/document/ai-risk-management-framework-2nd-draft\"\n      },\n      {\n        \"text\": \"Initial draft of the AI Risk Management Framework\",\n        \"url\": \"https://www.nist.gov/document/ai-risk-management-framework-initial-draft\"\n      },\n      {\n        \"text\": \"Concept paper to help guide development of the AI Risk Management Framework\",\n        \"url\": \"https://www.nist.gov/document/airmfconceptpaper\"\n      },\n      {\n        \"text\": \"Brief summary\",\n        \"url\": \"https://www.nist.gov/document/summary-analysis-responses-nist-artificial-intelligence-risk-management-framework-ai-rmf\"\n      },\n      {\n        \"text\": \"responses\",\n        \"url\": \"https://www.nist.gov/itl/ai-risk-management-framework/comments-received-rfi-artificial-intelligence-risk-management\"\n      },\n      {\n        \"text\": \"Draft -Taxonomy of AI Risk\",\n        \"url\": \"https://www.nist.gov/document/draft-taxonomy-ai-risk-october-15-2021\"\n      },\n      {\n        \"text\": \"AI Risk Management Framework Request for Information\",\n        \"url\": \"https://www.federalregister.gov/documents/2021/07/29/2021-16176/artificial-intelligence-risk-management-framework\"\n      },\n      {\n        \"text\": \"Was this page helpful?\",\n        \"url\": \"https://www.nist.gov/webform/page_feedback?page=https://www.nist.gov/itl/ai-risk-management-framework&page_title=AI Risk Management Framework&source_entity_type=node&source_entity_id=1674601\"\n      }\n    ]\n  },\n  \"isError\": false\n}","toolCallId":"toolu_bdrk_01B8sswHA79jwkApUVcF3n13","timestamp":"2026-02-21T00:27:37.609Z","source":"database","confirmed":true}

event: mcp_calls_data
data: {"calls":[{"id":"toolu_bdrk_01DXfr6JiSAUF2a7cCmqkghK","name":"web_fetch","tool":"web_fetch","toolName":"web_fetch","serverId":"openagentic_web","serverName":"openagentic_web","executedOn":"mcp-proxy","arguments":{"url":"https://www.fedramp.gov/ai/","max_length":50000},"result":{"content":[{"type":"text","text":"{\"success\":true,\"cached\":false,\"url\":\"https://www.fedramp.gov/ai/\",\"title\":\"FedRAMP AI\",\"content\":\"![Mountain background](/mountain_abstract.svg)\\n\\n# FedRAMP AI Prioritization\\n\\n**Effective Date: Monday, August 18, 2025**\\n\\nIn response to formal recommendations from the FedRAMP Board (by electronic vote) and the Chief Information Officers Council (by electronic notification), FedRAMP will begin prioritizing certain AI cloud services for FedRAMP authorization. This page explains the criteria and process for prioritization as required by the FedRAMP Authorization Act.\\n\\n## Prioritization Criteria\\n\\nFedRAMP is now prioritizing the authorization of AI-based cloud services that provide access to conversational AI engines designed for routine and repeated use by federal workers. To ensure this prioritization in the best interest of the federal government, such services must meet all of the following criteria to be prioritized:\\n\\n* Offer enterprise-grade features including single-sign on, SCIM provisioning, role-based access control, and real-time analytics\\n* Guarantee data separation and protection; any model information from training on customer data will not leave the customer environment without customer authorization\\n* Establish demand from at least five CFO Act agencies or be specifically recommended by the CIO Council\\n* Be available for government use via the GSA Multiple Award Schedule program\\n* Be able to meet the requirements for a FedRAMP 20x authorization within two months of acceptance for prioritization\\n\\n## Prioritization Process\\n\\nCloud service providers who receive prioritization under this criteria will follow a separate process similar to the FedRAMP 20x Phase One pilot:\\n\\n* Cloud service providers who meet this criteria should reach out directly to the FedRAMP Director via [pete@fedramp.gov](mailto:pete@fedramp.gov) to discuss next steps.\\n* Providers will be required to meet all [Initial Submission Requirements for the 20x Phase One pilot](/20x/phase-one).\\n* Providers will receive additional pre-submission support from FedRAMP.\\n* 20xP1 pilot submissions will be accepted outside the standard submission window; there is no deadline for submission.\\n* Providers will receive additional post-authorization support from FedRAMP and the FedRAMP Board to encourage adoption.\\n\\n## List of Prioritized Services\\n\\n### [ChatGPT Enterprise and API Platform, by OpenAI](https://marketplace.fedramp.gov/products/FR2533155773)\\n\\n* *On track for FedRAMP 20x Low authorization by January 2026*\\n\\n### [Gemini for Government, by Google](https://marketplace.fedramp.gov/products/FR2604952026)\\n\\n* *On track for FedRAMP 20x Low authorization by January 2026*\\n\\n### [Perplexity Enterprise Pro for Government, by Perplexity AI, Inc.](https://marketplace.fedramp.gov/products/FR2604643715)\\n\\n* *On track for FedRAMP 20x Low authorization by January 2026*\\n\\nAdditional services will be added to this list as they meet the prioritization criteria and begin working on FedRAMP 20x.\\n\\n[![GSA logo](/gsa-star-mark-whtlogo.svg)](https://www.gsa.gov/)\\n\\nFedRAMP.gov\\n\\nAn official website of the GSA’s [Technology Transformation Services](https://www.gsa.gov/about-us/organization/federal-acquisition-service/technology-transformation-services)\\n\\nLooking for U.S. government information and services?\\n\\n[Visit USA.gov](https://www.usa.gov/)\\n\\n Top\",\"content_length\":3243,\"links\":[{\"text\":\"Initial Submission Requirements for the 20x Phase One pilot\",\"url\":\"https://www.fedramp.gov/20x/phase-one\"},{\"text\":\"ChatGPT Enterprise and API Platform, by OpenAI\",\"url\":\"https://marketplace.fedramp.gov/products/FR2533155773\"},{\"text\":\"Gemini for Government, by Google\",\"url\":\"https://marketplace.fedramp.gov/products/FR2604952026\"},{\"text\":\"Perplexity Enterprise Pro for Government, by Perplexity AI, Inc.\",\"url\":\"https://marketplace.fedramp.gov/products/FR2604643715\"},{\"text\":\"Technology Transformation Services\",\"url\":\"https://www.gsa.gov/about-us/organization/federal-acquisition-service/technology-transformation-services\"},{\"text\":\"Visit USA.gov\",\"url\":\"https://www.usa.gov/\"}]}"}],"structuredContent":{"success":true,"cached":false,"url":"https://www.fedramp.gov/ai/","title":"FedRAMP AI","content":"![Mountain background](/mountain_abstract.svg)\n\n# FedRAMP AI Prioritization\n\n**Effective Date: Monday, August 18, 2025**\n\nIn response to formal recommendations from the FedRAMP Board (by electronic vote) and the Chief Information Officers Council (by electronic notification), FedRAMP will begin prioritizing certain AI cloud services for FedRAMP authorization. This page explains the criteria and process for prioritization as required by the FedRAMP Authorization Act.\n\n## Prioritization Criteria\n\nFedRAMP is now prioritizing the authorization of AI-based cloud services that provide access to conversational AI engines designed for routine and repeated use by federal workers. To ensure this prioritization in the best interest of the federal government, such services must meet all of the following criteria to be prioritized:\n\n* Offer enterprise-grade features including single-sign on, SCIM provisioning, role-based access control, and real-time analytics\n* Guarantee data separation and protection; any model information from training on customer data will not leave the customer environment without customer authorization\n* Establish demand from at least five CFO Act agencies or be specifically recommended by the CIO Council\n* Be available for government use via the GSA Multiple Award Schedule program\n* Be able to meet the requirements for a FedRAMP 20x authorization within two months of acceptance for prioritization\n\n## Prioritization Process\n\nCloud service providers who receive prioritization under this criteria will follow a separate process similar to the FedRAMP 20x Phase One pilot:\n\n* Cloud service providers who meet this criteria should reach out directly to the FedRAMP Director via [pete@fedramp.gov](mailto:pete@fedramp.gov) to discuss next steps.\n* Providers will be required to meet all [Initial Submission Requirements for the 20x Phase One pilot](/20x/phase-one).\n* Providers will receive additional pre-submission support from FedRAMP.\n* 20xP1 pilot submissions will be accepted outside the standard submission window; there is no deadline for submission.\n* Providers will receive additional post-authorization support from FedRAMP and the FedRAMP Board to encourage adoption.\n\n## List of Prioritized Services\n\n### [ChatGPT Enterprise and API Platform, by OpenAI](https://marketplace.fedramp.gov/products/FR2533155773)\n\n* *On track for FedRAMP 20x Low authorization by January 2026*\n\n### [Gemini for Government, by Google](https://marketplace.fedramp.gov/products/FR2604952026)\n\n* *On track for FedRAMP 20x Low authorization by January 2026*\n\n### [Perplexity Enterprise Pro for Government, by Perplexity AI, Inc.](https://marketplace.fedramp.gov/products/FR2604643715)\n\n* *On track for FedRAMP 20x Low authorization by January 2026*\n\nAdditional services will be added to this list as they meet the prioritization criteria and begin working on FedRAMP 20x.\n\n[![GSA logo](/gsa-star-mark-whtlogo.svg)](https://www.gsa.gov/)\n\nFedRAMP.gov\n\nAn official website of the GSA’s [Technology Transformation Services](https://www.gsa.gov/about-us/organization/federal-acquisition-service/technology-transformation-services)\n\nLooking for U.S. government information and services?\n\n[Visit USA.gov](https://www.usa.gov/)\n\n Top","content_length":3243,"links":[{"text":"Initial Submission Requirements for the 20x Phase One pilot","url":"https://www.fedramp.gov/20x/phase-one"},{"text":"ChatGPT Enterprise and API Platform, by OpenAI","url":"https://marketplace.fedramp.gov/products/FR2533155773"},{"text":"Gemini for Government, by Google","url":"https://marketplace.fedramp.gov/products/FR2604952026"},{"text":"Perplexity Enterprise Pro for Government, by Perplexity AI, Inc.","url":"https://marketplace.fedramp.gov/products/FR2604643715"},{"text":"Technology Transformation Services","url":"https://www.gsa.gov/about-us/organization/federal-acquisition-service/technology-transformation-services"},{"text":"Visit USA.gov","url":"https://www.usa.gov/"}]},"isError":false},"status":"completed","startTime":1771633656075,"endTime":1771633657609,"duration":1534,"timestamp":"2026-02-21T00:27:37.609Z"},{"id":"toolu_bdrk_01B8sswHA79jwkApUVcF3n13","name":"web_fetch","tool":"web_fetch","toolName":"web_fetch","serverId":"openagentic_web","serverName":"openagentic_web","executedOn":"mcp-proxy","arguments":{"url":"https://www.nist.gov/itl/ai-risk-management-framework","max_length":50000},"result":{"content":[{"type":"text","text":"{\"success\":true,\"cached\":false,\"url\":\"https://www.nist.gov/itl/ai-risk-management-framework\",\"title\":\"AI Risk Management Framework | NIST\",\"content\":\"[![Circular design includes elements of the AI Risk Management Framework: Govern, Measure, Manage, Map.](/sites/default/files/styles/thumbnail/public/images/2023/01/25/RMF-redesign-rounded-other_graphics-04.png?itok=q6XNzk9H)](/news-events/news/2023/01/nist-risk-management-framework-aims-improve-trustworthiness-artificial)\\n\\nNew guidance seeks to cultivate trust in AI technologies and promote AI innovation while mitigating risk.\",\"content_length\":431,\"links\":[{\"text\":\"Skip to main content\",\"url\":\"https://www.nist.gov/itl/ai-risk-management-framework#main-content\"},{\"text\":\"Information Technology Laboratory\",\"url\":\"https://www.nist.gov/itl\"},{\"text\":\"Download the AI RMF 1.0\",\"url\":\"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.pdf\"},{\"text\":\"View the AI RMF Playbook\",\"url\":\"https://airc.nist.gov/airmf-resources/playbook/\"},{\"text\":\"Visit the AI Resource Center\",\"url\":\"https://airc.nist.gov/\"},{\"text\":\"NIST AI Risk Management Framework (AI RMF)\",\"url\":\"https://doi.org/10.6028/NIST.AI.100-1\"},{\"text\":\"workshops\",\"url\":\"https://www.nist.gov/artificial-intelligence/nist-ai-engagement\"},{\"text\":\"Fact Sheet\",\"url\":\"https://www.nist.gov/document/about-nist-ai-rmf\"},{\"text\":\"NIST AI RMF Playbook\",\"url\":\"https://airc.nist.gov/AI_RMF_Knowledge_Base/Playbook\"},{\"text\":\"AI RMF Roadmap\",\"url\":\"https://www.nist.gov/itl/ai-risk-management-framework/roadmap-nist-artificial-intelligence-risk-management-framework-ai\"},{\"text\":\"AI RMF Crosswalk\",\"url\":\"https://www.nist.gov/itl/ai-risk-management-framework/crosswalks-nist-artificial-intelligence-risk-management-framework\"},{\"text\":\"Perspectives\",\"url\":\"https://www.nist.gov/itl/ai-risk-management-framework/perspectives-about-nist-artificial-intelligence-risk-management\"},{\"text\":\"Trustworthy and Responsible AI Resource Center\",\"url\":\"https://airc.nist.gov/Home\"},{\"text\":\"AIRC’s Use Case page\",\"url\":\"https://airc.nist.gov/Usecases\"},{\"text\":\"NIST-AI-600-1, Artificial Intelligence Risk Management Framework: Generative Artificial Intelligence\",\"url\":\"https://doi.org/10.6028/NIST.AI.600-1\"},{\"text\":\"AI RMF Development\",\"url\":\"https://www.nist.gov/itl/ai-risk-management-framework/ai-rmf-development\"},{\"text\":\"NIST AI Risk Management Framework\",\"url\":\"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.ara.pdf\"},{\"text\":\"NIST AI Risk Management Framework\",\"url\":\"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.jpn.pdf\"},{\"text\":\"Second draft of the AI Risk Management Framework\",\"url\":\"https://www.nist.gov/document/ai-risk-management-framework-2nd-draft\"},{\"text\":\"Initial draft of the AI Risk Management Framework\",\"url\":\"https://www.nist.gov/document/ai-risk-management-framework-initial-draft\"},{\"text\":\"Concept paper to help guide development of the AI Risk Management Framework\",\"url\":\"https://www.nist.gov/document/airmfconceptpaper\"},{\"text\":\"Brief summary\",\"url\":\"https://www.nist.gov/document/summary-analysis-responses-nist-artificial-intelligence-risk-management-framework-ai-rmf\"},{\"text\":\"responses\",\"url\":\"https://www.nist.gov/itl/ai-risk-management-framework/comments-received-rfi-artificial-intelligence-risk-management\"},{\"text\":\"Draft -Taxonomy of AI Risk\",\"url\":\"https://www.nist.gov/document/draft-taxonomy-ai-risk-october-15-2021\"},{\"text\":\"AI Risk Management Framework Request for Information\",\"url\":\"https://www.federalregister.gov/documents/2021/07/29/2021-16176/artificial-intelligence-risk-management-framework\"},{\"text\":\"Was this page helpful?\",\"url\":\"https://www.nist.gov/webform/page_feedback?page=https://www.nist.gov/itl/ai-risk-management-framework&page_title=AI Risk Management Framework&source_entity_type=node&source_entity_id=1674601\"}]}"}],"structuredContent":{"success":true,"cached":false,"url":"https://www.nist.gov/itl/ai-risk-management-framework","title":"AI Risk Management Framework | NIST","content":"[![Circular design includes elements of the AI Risk Management Framework: Govern, Measure, Manage, Map.](/sites/default/files/styles/thumbnail/public/images/2023/01/25/RMF-redesign-rounded-other_graphics-04.png?itok=q6XNzk9H)](/news-events/news/2023/01/nist-risk-management-framework-aims-improve-trustworthiness-artificial)\n\nNew guidance seeks to cultivate trust in AI technologies and promote AI innovation while mitigating risk.","content_length":431,"links":[{"text":"Skip to main content","url":"https://www.nist.gov/itl/ai-risk-management-framework#main-content"},{"text":"Information Technology Laboratory","url":"https://www.nist.gov/itl"},{"text":"Download the AI RMF 1.0","url":"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.pdf"},{"text":"View the AI RMF Playbook","url":"https://airc.nist.gov/airmf-resources/playbook/"},{"text":"Visit the AI Resource Center","url":"https://airc.nist.gov/"},{"text":"NIST AI Risk Management Framework (AI RMF)","url":"https://doi.org/10.6028/NIST.AI.100-1"},{"text":"workshops","url":"https://www.nist.gov/artificial-intelligence/nist-ai-engagement"},{"text":"Fact Sheet","url":"https://www.nist.gov/document/about-nist-ai-rmf"},{"text":"NIST AI RMF Playbook","url":"https://airc.nist.gov/AI_RMF_Knowledge_Base/Playbook"},{"text":"AI RMF Roadmap","url":"https://www.nist.gov/itl/ai-risk-management-framework/roadmap-nist-artificial-intelligence-risk-management-framework-ai"},{"text":"AI RMF Crosswalk","url":"https://www.nist.gov/itl/ai-risk-management-framework/crosswalks-nist-artificial-intelligence-risk-management-framework"},{"text":"Perspectives","url":"https://www.nist.gov/itl/ai-risk-management-framework/perspectives-about-nist-artificial-intelligence-risk-management"},{"text":"Trustworthy and Responsible AI Resource Center","url":"https://airc.nist.gov/Home"},{"text":"AIRC’s Use Case page","url":"https://airc.nist.gov/Usecases"},{"text":"NIST-AI-600-1, Artificial Intelligence Risk Management Framework: Generative Artificial Intelligence","url":"https://doi.org/10.6028/NIST.AI.600-1"},{"text":"AI RMF Development","url":"https://www.nist.gov/itl/ai-risk-management-framework/ai-rmf-development"},{"text":"NIST AI Risk Management Framework","url":"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.ara.pdf"},{"text":"NIST AI Risk Management Framework","url":"https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.100-1.jpn.pdf"},{"text":"Second draft of the AI Risk Management Framework","url":"https://www.nist.gov/document/ai-risk-management-framework-2nd-draft"},{"text":"Initial draft of the AI Risk Management Framework","url":"https://www.nist.