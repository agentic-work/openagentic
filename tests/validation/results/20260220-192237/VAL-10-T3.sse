      <div class=\"label\">Cluster Nodes</div>\n      <div class=\"value green\">6 / 6</div>\n      <div class=\"trend green\">All nodes reporting</div>\n    </div>\n  </div>\n</div>\n\n<!-- Service Status -->\n<div class=\"section\">\n  <h2>Per-Service Status</h2>\n  <div class=\"svc-grid\">\n    <div class=\"svc-card ok\"><div class=\"svc-dot ok\"></div><div class=\"svc-info\"><div class=\"svc-name\">API Server</div><div class=\"svc-detail\">10.42.5.20:8000 · agentic-dev</div></div><div class=\"svc-badge ok\">Healthy</div></div>\n    <div class=\"svc-card ok\"><div class=\"svc-dot ok\"></div><div class=\"svc-info\"><div class=\"svc-name\">MCP Proxy</div><div class=\"svc-detail\">10.42.5.25:8080 · routing to 12 MCP servers</div></div><div class=\"svc-badge ok\">Healthy</div></div>\n    <div class=\"svc-card ok\"><div class=\"svc-dot ok\"></div><div class=\"svc-info\"><div class=\"svc-name\">LangGraph</div><div class=\"svc-detail\">10.42.1.91:3100 · default framework</div></div><div class=\"svc-badge ok\">Healthy</div></div>\n    <div class=\"svc-card ok\"><div class=\"svc-dot ok\"></div><div class=\"svc-info\"><div class=\"svc-name\">CrewAI</div><div class=\"svc-detail\">10.42.1.90:3200 · multi-agent orchestration</div></div><div class=\"svc-badge ok\">Healthy</div></div>\n    <div class=\"svc-card warn\"><div class=\"svc-dot warn\"></div><div class=\"svc-info\"><div class=\"svc-name\">PostgreSQL</div><div class=\"svc-detail\">Running · FK violations on user_query_audit</div></div><div class=\"svc-badge warn\">Degraded</div></div>\n    <div class=\"svc-card warn\"><div class=\"svc-dot warn\"></div><div class=\"svc-info\"><div class=\"svc-name\">Milvus Vector DB</div><div class=\"svc-detail\">Running · schema errors, missing collections</div></div><div class=\"svc-badge warn\">Degraded</div></div>\n    <div class=\"svc-card err\"><div class=\"svc-dot err\"></div><div class=\"svc-info\"><div class=\"svc-name\">Flowise</div><div class=\"svc-detail\">openagentic-api:80