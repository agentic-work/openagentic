{
  "name": "@openagentic/test-harness",
  "version": "0.6.0",
  "description": "Comprehensive test harness for OpenAgentic platform",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:load": "k6 run load/scenarios/smoke.js",
    "test:load:stress": "k6 run load/scenarios/stress.js",
    "test:contracts": "vitest run --config vitest.contracts.config.ts",
    "verify:deployment": "python3 verify-deployment/verify_deployment.py",
    "verify:deployment:test": "python3 verify-deployment/test_harness_lib.py",
    "test:all": "npm run test && npm run test:e2e && npm run test:integration",
    "report": "allure generate ./reports/allure-results -o ./reports/allure-report --clean",
    "report:open": "allure open ./reports/allure-report",
    "dashboard": "vite --config ui-dashboard/vite.config.ts",
    "dashboard:build": "vite build --config ui-dashboard/vite.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.5",
    "msw": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.0",
    "socket.io-client": "^4.7.0",
    "tailwindcss": "^3.4.0",
    "testcontainers": "^10.28.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
