# OpenAgentic — Compose env
# Copy to .env and adjust as needed. Anything left blank uses sensible defaults.

# ─── Postgres ───────────────────────────────────────────────────────────────
# install.sh / the setup wizard generates a strong random value for the password
# on first run. If you edit this file by hand, replace the placeholder with a
# long random string before running docker compose up.
POSTGRES_PASSWORD=REPLACE_ME_AT_INSTALL_TIME
POSTGRES_DB=openagentic
POSTGRES_USER=openagentic

# ─── Internal service secrets (REQUIRED — no weak defaults) ─────────────────
# These are the inter-service trust roots. docker-compose.yml requires each via
# ${VAR:?...} (a bare `docker compose up` fails fast if any is unset), and the
# api fails CLOSED in production on a missing/weak value. install.sh / the setup
# wizard generates a strong random value for each on first run. If you edit this
# file by hand, replace EVERY placeholder with a long random string
# (e.g. `openssl rand -hex 32`) before running docker compose up.
#   JWT_SECRET              — signs/validates user + session JWTs
#   SIGNING_SECRET          — signs internal HS256 inter-service tokens
#   INTERNAL_API_KEY        — api↔mcp-proxy service-account bearer
#   FRONTEND_SECRET         — ui session secret
#   INTERNAL_SERVICE_SECRET — mints/HMAC-verifies the oa_sys_ inter-service token
#                             (api and mcp-proxy MUST share the same value)
JWT_SECRET=REPLACE_ME_AT_INSTALL_TIME
SIGNING_SECRET=REPLACE_ME_AT_INSTALL_TIME
INTERNAL_API_KEY=REPLACE_ME_AT_INSTALL_TIME
FRONTEND_SECRET=REPLACE_ME_AT_INSTALL_TIME
INTERNAL_SERVICE_SECRET=REPLACE_ME_AT_INSTALL_TIME

# ─── Ollama (OPT-IN — only if you choose Ollama as your provider) ───────────
# The platform is provider-agnostic and starts NO provider by default. Ollama is
# OFF unless you turn it on here. To use Ollama:
#   OLLAMA_ENABLED=true
#   # then either run the bundled container:  docker compose --profile ollama up -d
#   # or point at an Ollama you already run on the host:
#   # OLLAMA_HOST=http://host.docker.internal:11434
#   EMBEDDING_PROVIDER=ollama
#   # and seed it as the bootstrap provider so chat works out of the box:
#   BOOTSTRAP_PROVIDER_NAME=ollama-local
#   BOOTSTRAP_PROVIDER_TYPE=ollama
# A bare `docker compose up` (no provider set) boots healthy and waits for you to
# pick a provider in the admin UI.
# OLLAMA_ENABLED=false
# OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Optional chat model tag for the bundled ollama (pre-pulled by --profile ollama).
# OLLAMA_CHAT_MODEL=llama3.2:3b

# ─── LLM provider keys (all optional — set whatever you have) ───────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── Auth ───────────────────────────────────────────────────────────────────
# Local username/password auth only (credentials stored in Postgres). There is
# no federated identity / SSO in OSS; set the initial admin in the section below.
# AUTH_PROVIDER=local
# LOCAL_LOGIN_ENABLED=true

# ─── Initial admin user (local auth) ────────────────────────────────────────
# Seeded on first boot. CHANGE THESE before you first start the stack.
ADMIN_USER_EMAIL=admin@openagentic.local
ADMIN_SEED_PASSWORD=REPLACE_ME_AT_INSTALL_TIME
LOCAL_ADMIN_USERNAME=Admin

# ─── Container images ──────────────────────────────────────────────────────
# Where docker compose pulls openagentic-* images from. Defaults to the
# public registry. Override to self-host or air-gap.
OPENAGENTIC_REGISTRY=ghcr.io/agentic-work
OPENAGENTIC_TAG=latest

# ─── Misc ───────────────────────────────────────────────────────────────────
# Host port the UI is exposed on (browser hits http://localhost:${UI_HOST_PORT})
UI_HOST_PORT=8080
