# OpenAgentic — Compose env
# Copy to .env and adjust as needed. Anything left blank uses sensible defaults.

# ─── Postgres ───────────────────────────────────────────────────────────────
# install.sh / the setup wizard generates a strong random value for the password
# on first run. If you edit this file by hand, replace the placeholder with a
# long random string before running docker compose up.
POSTGRES_PASSWORD=REPLACE_ME_AT_INSTALL_TIME
POSTGRES_DB=openagentic
POSTGRES_USER=openagentic

# ─── Ollama (REQUIRED for semantic tool indexing) ───────────────────────────
# Point at a remote Ollama with models already loaded, or leave unset to use
# the ollama container baked into this compose (pulls nomic-embed-text on boot).
# OLLAMA_HOST=http://hal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Optionally pre-pull a chat model into the LOCAL compose ollama so users have
# something to talk to with no API keys. Ignored when OLLAMA_HOST is remote.
# OLLAMA_CHAT_MODEL=llama3.2:3b

# ─── LLM provider keys (all optional — set whatever you have) ───────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── Auth ───────────────────────────────────────────────────────────────────
# Default is LOCAL ONLY (username/password stored in Postgres). If you want to
# enable Google or Microsoft/Entra sign-in, flip the matching LOGIN_ENABLED
# flag below AND provide the OAuth credentials.
# AUTH_PROVIDER=local                  # local | google | azure-ad | all
# GOOGLE_LOGIN_ENABLED=false
# MICROSOFT_LOGIN_ENABLED=false
# LOCAL_LOGIN_ENABLED=true
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=

# ─── Initial admin user (local auth) ────────────────────────────────────────
# Seeded on first boot. CHANGE THESE before you first start the stack.
ADMIN_USER_EMAIL=admin@openagentic.local
ADMIN_SEED_PASSWORD=changeme-on-first-login
LOCAL_ADMIN_USERNAME=Admin

# ─── Code Mode coding CLI ───────────────────────────────────────────────────
# Which CLI should the exec sandbox default to when a user opens Code Mode?
#   claude-code  → Anthropic (bundled, requires ANTHROPIC_API_KEY)
#   gemini-cli   → Google    (bundled, requires GEMINI_API_KEY / GOOGLE_GENERATIVE_AI_API_KEY)
#   none         → bare shell
# Users can override per-session from the Code Mode UI.
CODING_ADAPTER=claude-code

# ─── Misc ───────────────────────────────────────────────────────────────────
# Host port the UI is exposed on (browser hits http://localhost:${UI_HOST_PORT})
UI_HOST_PORT=8080
