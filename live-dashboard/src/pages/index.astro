---
// OpenAgentic Chat Pipeline — Live Build Dashboard
// Fully client-rendered from /status.json (polled), so controller updates show live.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>OpenAgentic Chat Pipeline — Live Build</title>
  <style is:global>
    :root{
      --bg:#05070d; --panel:#0b1018; --panel2:#0e1521; --line:#1b2740;
      --ink:#e6edf7; --dim:#7f8ba3; --faint:#4a5570;
      --live:#37f5a3; --build:#ffc24d; --broken:#ff5d6c; --flow:#49b6ff; --vio:#b78cff;
      --glowlive:rgba(55,245,163,.45); --glowbuild:rgba(255,194,77,.5); --glowbroke:rgba(255,93,108,.45); --glowwork:rgba(183,140,255,.55);
      --mono:"SFMono-Regular",ui-monospace,"JetBrains Mono",Menlo,Consolas,monospace;
    }
    *{box-sizing:border-box}
    html,body{margin:0;height:100%;background:var(--bg);color:var(--ink);
      font-family:var(--mono);font-size:13px;line-height:1.45;-webkit-font-smoothing:antialiased}
    body{background:
      radial-gradient(1200px 600px at 80% -10%, rgba(73,182,255,.07), transparent 60%),
      radial-gradient(900px 500px at 10% 110%, rgba(183,140,255,.06), transparent 60%),
      linear-gradient(var(--bg),var(--bg));
      background-attachment:fixed; overflow:hidden}
    body::before{content:"";position:fixed;inset:0;pointer-events:none;opacity:.35;
      background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);
      background-size:46px 46px; mask:radial-gradient(circle at 50% 40%, #000 30%, transparent 80%)}
    .app{display:grid;grid-template-columns:340px 1fr;grid-template-rows:64px 1fr;height:100vh}
    header{grid-column:1/3;display:flex;align-items:center;gap:18px;padding:0 22px;
      border-bottom:1px solid var(--line);background:linear-gradient(180deg,rgba(11,16,24,.9),rgba(5,7,13,.5));backdrop-filter:blur(6px)}
    .brand{font-weight:700;letter-spacing:.5px;font-size:15px}
    .brand b{color:var(--flow)}
    .pulse{width:9px;height:9px;border-radius:50%;background:var(--live);box-shadow:0 0 0 0 var(--glowlive);animation:pulse 1.8s infinite}
    @keyframes pulse{0%{box-shadow:0 0 0 0 var(--glowlive)}70%{box-shadow:0 0 0 12px transparent}100%{box-shadow:0 0 0 0 transparent}}
    .hl{color:var(--dim);font-size:12px}
    .sha{margin-left:auto;display:flex;gap:14px;color:var(--dim);font-size:12px}
    .sha b{color:var(--ink)}
    .tag{padding:2px 8px;border:1px solid var(--line);border-radius:999px;color:var(--dim)}
    aside{border-right:1px solid var(--line);background:linear-gradient(180deg,var(--panel),var(--bg));
      overflow-y:auto;padding:14px}
    main{position:relative;overflow:hidden;display:flex;flex-direction:column}
    .sect{font-size:10.5px;letter-spacing:1.4px;text-transform:uppercase;color:var(--faint);margin:6px 4px 8px}
    .scorebar{display:flex;gap:8px;margin:0 2px 14px}
    .score{flex:1;border:1px solid var(--line);border-radius:10px;padding:9px 10px;background:var(--panel2)}
    .score .n{font-size:22px;font-weight:700}
    .score .l{font-size:10px;color:var(--dim);letter-spacing:1px;text-transform:uppercase}
    .score.pass .n{color:var(--live)} .score.fail .n{color:var(--broken)} .score.unv .n{color:var(--build)}
    .item{border:1px solid var(--line);border-radius:10px;padding:9px 11px;margin-bottom:8px;background:var(--panel2);
      transition:transform .2s,border-color .3s}
    .item:hover{transform:translateX(3px);border-color:#26344f}
    .item .top{display:flex;align-items:center;gap:8px}
    .item .id{color:var(--flow);font-size:11px;font-weight:700}
    .item .ttl{font-size:12.5px}
    .item .note{color:var(--dim);font-size:11px;margin-top:3px}
    .dot{width:8px;height:8px;border-radius:50%;flex:none}
    .st-live,.st-done,.st-PASS{background:var(--live)}
    .st-building,.st-in_progress,.st-running{background:var(--build);animation:blink 1.1s infinite}
    .st-broken,.st-blocked,.st-FAIL{background:var(--broken)}
    .st-todo,.st-unverified{background:var(--faint)}
    @keyframes blink{50%{opacity:.3}}
    .pill{margin-left:auto;font-size:9.5px;letter-spacing:.6px;text-transform:uppercase;padding:2px 7px;border-radius:999px;border:1px solid var(--line);color:var(--dim)}
    .wf{display:flex;align-items:center;gap:8px;padding:7px 10px;border:1px solid var(--line);border-radius:10px;margin-bottom:7px;background:var(--panel2)}
    .wf .nm{font-size:12px}.wf .ph{color:var(--dim);font-size:11px;margin-left:auto}
    .livedot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--live,#37f5a3);margin-left:5px;animation:blink 1.3s infinite;vertical-align:middle}
    #events{max-height:230px;overflow-y:auto;padding-right:2px}
    .evrow{display:flex;gap:8px;padding:4px 2px;font-size:11px;border-left:2px solid var(--live,#37f5a3);padding-left:8px;margin-bottom:5px;background:linear-gradient(90deg,rgba(55,245,163,.06),transparent)}
    .evrow:first-child{animation:evin .6s ease}
    @keyframes evin{from{opacity:0;transform:translateX(-6px)}to{opacity:1;transform:none}}
    .evt{color:var(--faint);font-variant-numeric:tabular-nums;flex-shrink:0}
    .evm{color:var(--ink,#dfe8f5)}
    /* canvas */
    .stage{flex:1;position:relative}
    svg{position:absolute;inset:0;width:100%;height:100%}
    .edge{stroke:#243352;stroke-width:1.4;fill:none}
    .edge.flow{stroke:url(#flowg);stroke-width:2;stroke-dasharray:5 9;animation:dash 1.1s linear infinite}
    @keyframes dash{to{stroke-dashoffset:-28}}
    .node{cursor:default}
    .node rect{fill:var(--panel2);stroke:var(--line);stroke-width:1.4;rx:11}
    .node .lab{fill:var(--ink);font-size:12.5px;font-weight:700}
    .node .sub{fill:var(--dim);font-size:10px}
    .node.live rect{stroke:var(--live);filter:drop-shadow(0 0 7px var(--glowlive))}
    .node.building rect{stroke:var(--build);filter:drop-shadow(0 0 9px var(--glowbuild));animation:nbuild 1.6s ease-in-out infinite}
    .node.broken rect{stroke:var(--broken);filter:drop-shadow(0 0 8px var(--glowbroke))}
    .node.unverified rect{stroke:var(--faint);stroke-dasharray:5 4}
    .node.working rect{stroke:var(--vio);filter:drop-shadow(0 0 10px var(--glowwork));animation:nwork 1.3s ease-in-out infinite}
    @keyframes nbuild{50%{filter:drop-shadow(0 0 16px var(--glowbuild))}}
    @keyframes nwork{50%{filter:drop-shadow(0 0 18px var(--glowwork))}}
    .legend{position:absolute;left:16px;bottom:14px;display:flex;gap:16px;font-size:11px;color:var(--dim);
      background:rgba(5,7,13,.6);border:1px solid var(--line);border-radius:10px;padding:8px 12px}
    .legend span{display:inline-flex;align-items:center;gap:6px}
    .ticker{border-top:1px solid var(--line);background:var(--panel);padding:9px 16px;display:flex;gap:26px;overflow:hidden;white-space:nowrap;color:var(--dim);font-size:11.5px}
    .ticker b{color:var(--ink)}
    .battery{position:absolute;right:16px;top:14px;width:248px;background:rgba(5,7,13,.6);border:1px solid var(--line);border-radius:12px;padding:11px}
    .brow{display:flex;align-items:center;gap:8px;padding:5px 2px;font-size:11.5px;border-bottom:1px dashed #182338}
    .brow:last-child{border:0}
    .brow .g{flex:1}.brow .r{font-weight:700}
    .r.PASS{color:var(--live)} .r.FAIL{color:var(--broken)}
    .upd{position:absolute;right:16px;bottom:50px;color:var(--faint);font-size:10.5px;z-index:3}
    .tabs{display:flex;align-items:center;gap:8px;padding:10px 16px 0}
    .tab{background:var(--panel2);border:1px solid var(--line);color:var(--dim);border-radius:9px 9px 0 0;
      padding:8px 16px;font-family:var(--mono);font-size:12.5px;cursor:pointer;border-bottom:none;transition:.2s}
    .tab:hover{color:var(--ink)}
    .tab.active{color:var(--ink);background:var(--panel);border-color:#26344f;box-shadow:0 -2px 14px rgba(73,182,255,.14)}
    .tabs-legend{position:static;margin-left:auto;background:transparent;border:0;padding:0}
    .stage{border-top:1px solid var(--line)}
    .lane rect{fill:rgba(120,160,255,.018);stroke-width:1.3}
    .lane .ll{font-size:10.5px;letter-spacing:1.4px;text-transform:uppercase;font-weight:700;opacity:.85}
    .anode rect{fill:var(--panel2);stroke:var(--line);stroke-width:1.4}
    .anode .al{fill:var(--ink);font-size:12px;font-weight:700}
    .anode .as{fill:var(--dim);font-size:9.5px}
    .anode.live rect{stroke:var(--live);filter:drop-shadow(0 0 5px var(--glowlive))}
    .anode.building rect{stroke:var(--build);filter:drop-shadow(0 0 7px var(--glowbuild));animation:nbuild 1.6s ease-in-out infinite}
    .anode.broken rect{stroke:var(--broken);filter:drop-shadow(0 0 6px var(--glowbroke))}
    .anode.unverified rect{stroke:var(--faint);stroke-dasharray:5 4}
    .anode.working rect{stroke:var(--vio);filter:drop-shadow(0 0 9px var(--glowwork));animation:nwork 1.3s ease-in-out infinite}
    .dgrid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .iflt{border:1px solid var(--vio);border-radius:10px;padding:9px 12px;background:rgba(183,140,255,.06)}
    .iflt .ifn{display:inline-block;font-family:var(--mono);font-size:10px;color:var(--vio);background:rgba(183,140,255,.12);border-radius:5px;padding:1px 7px;margin-right:8px}
    .iflt .ift{font-weight:700;font-size:13px;color:var(--ink)}
    .iflt .ifnote{color:var(--dim);font-size:11px;margin-top:5px}
    .aedge{stroke:#2a3a59;stroke-width:1.3;fill:none}
    .aedge.hot{stroke:#3d5a86;stroke-width:1.6}
    .elabel{fill:var(--faint);font-size:9px}
    .dnote{color:var(--dim);font-size:13px;line-height:1.6;max-width:820px;border-left:3px solid var(--flow);padding-left:14px}
    .dnote b{color:var(--ink)}
    .dgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:980px}
    .ddoc{border:1px solid var(--line);border-radius:11px;padding:12px 14px;background:var(--panel2);transition:.2s}
    .ddoc:hover{border-color:#2a3a59;transform:translateY(-2px)}
    .ddoc .p{color:var(--flow);font-size:12.5px;font-weight:700;word-break:break-all}
    .ddoc .r{color:var(--dim);font-size:11.5px;margin-top:5px;line-height:1.5}
    .acbig{display:flex;gap:12px;max-width:760px}
    .acb{flex:1;border:1px solid var(--line);border-radius:12px;padding:14px 16px;background:var(--panel2);text-align:center}
    .acb span{display:block;font-size:30px;font-weight:700}
    .acb small{color:var(--dim);font-size:10px;letter-spacing:.5px;text-transform:uppercase}
    .acb.pass span{color:var(--live)}.acb.fail span{color:var(--broken)}.acb.unv span{color:var(--build)}.acb.tot span{color:var(--ink)}
  </style>
</head>
<body>
  <div class="app">
    <header>
      <span class="pulse"></span>
      <span class="brand">Agentic<b>Work</b> · Chat Pipeline <span class="hl">— live build</span></span>
      <span id="headline" class="hl"></span>
      <span class="sha" id="sha"></span>
    </header>

    <aside>
      <div class="sect">Acceptance · 38 gates</div>
      <div class="scorebar">
        <div class="score pass"><div class="n" id="sc-pass">–</div><div class="l">Pass</div></div>
        <div class="score fail"><div class="n" id="sc-fail">–</div><div class="l">Fail</div></div>
        <div class="score unv"><div class="n" id="sc-unv">–</div><div class="l">Unver</div></div>
      </div>
      <div class="sect">Work Left</div>
      <div id="workleft"></div>
      <div class="sect">Workflows</div>
      <div id="workflows"></div>
      <div class="sect">Live Activity <span class="livedot"></span></div>
      <div id="events"></div>
    </aside>

    <main>
      <div class="tabs">
        <button class="tab active" data-tab="flow">&#10227;&nbsp; Pipeline Data Flow</button>
        <button class="tab" data-tab="arch">&#9638;&nbsp; Full Architecture</button>
        <button class="tab" data-tab="design">&#9776;&nbsp; Design &amp; AC</button>
        <div class="legend tabs-legend">
          <span><i class="dot st-live"></i>live</span>
          <span><i class="dot st-building"></i>building</span>
          <span><i class="dot st-broken"></i>broken</span>
          <span><i class="dot st-unverified"></i>unverified</span>
        </div>
      </div>

      <div class="stage" id="view-flow">
        <svg id="diagram" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="flowg" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#49b6ff" stop-opacity="0"/>
              <stop offset="50%" stop-color="#49b6ff"/>
              <stop offset="100%" stop-color="#b78cff" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <g id="edges"></g>
          <g id="nodes"></g>
        </svg>
        <div class="battery">
          <div class="sect" style="margin:0 0 6px">Live Battery</div>
          <div id="battery"></div>
        </div>
      </div>

      <div class="stage" id="view-arch" style="display:none">
        <svg id="archsvg" viewBox="0 0 1180 600" preserveAspectRatio="xMidYMid meet">
          <defs>
            <marker id="arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path d="M0 0 L10 5 L0 10 z" fill="#3a4a6b"/>
            </marker>
          </defs>
          <g id="arch-lanes"></g>
          <g id="arch-edges"></g>
          <g id="arch-nodes"></g>
        </svg>
      </div>

      <div class="stage" id="view-design" style="display:none;overflow:auto;padding:22px 28px">
        <div class="dnote">The diagrams above are the <b>design of record</b>. These docs define the same end-state architecture + the 38-gate acceptance contract the AC scorecard tracks — so what you see live == the design.</div>
        <div class="sect" style="margin:18px 2px 10px">Design &amp; AC documents</div>
        <div id="designdocs" class="dgrid"></div>
        <div class="sect" style="margin:22px 2px 10px">Acceptance · live rollup</div>
        <div class="acbig">
          <div class="acb pass"><span id="d-pass">–</span><small>PASS · real-model-proven</small></div>
          <div class="acb fail"><span id="d-fail">–</span><small>FAIL · root-caused</small></div>
          <div class="acb unv"><span id="d-unv">–</span><small>UNVERIFIED · live leg owed</small></div>
          <div class="acb tot"><span id="d-tot">–</span><small>total gates</small></div>
        </div>

        <div class="sect" style="margin:24px 2px 10px">In Flight <span class="livedot"></span> <small style="color:var(--vio);text-transform:none;letter-spacing:0">— arch component being worked now</small></div>
        <div id="d-inflight" class="dgrid2"></div>
        <div class="sect" style="margin:22px 2px 10px">Workflows · live</div>
        <div id="d-workflows"></div>
        <div class="sect" style="margin:22px 2px 10px">Live TODO</div>
        <div id="d-todo"></div>
      </div>

      <div class="upd" id="upd"></div>
      <div class="ticker" id="ticker"></div>
    </main>
  </div>

  <script type="module">
    const NW = 168, NH = 52;
    const $ = (id) => document.getElementById(id);
    function esc(s){return String(s).replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]))}

    const NS='http://www.w3.org/2000/svg';
    const mk=(t,attrs,text)=>{const e=document.createElementNS(NS,t);for(const k in attrs)e.setAttribute(k,attrs[k]);if(text!=null)e.textContent=text;return e;};
    function renderDiagram(arch){
      const nodes = arch.nodes, byId = Object.fromEntries(nodes.map(n=>[n.id,n]));
      const eG = $('edges'), nG = $('nodes');
      while(eG.firstChild) eG.removeChild(eG.firstChild);
      while(nG.firstChild) nG.removeChild(nG.firstChild);
      for(const [a,b] of arch.edges){
        const A=byId[a],B=byId[b]; if(!A||!B) continue;
        const x1=A.x+NW/2, y1=A.y+NH/2, x2=B.x+NW/2, y2=B.y+NH/2;
        const mx=(x1+x2)/2;
        const flow = A.status==='live'||A.status==='building';
        eG.appendChild(mk('path',{d:`M ${x1} ${y1} C ${mx} ${y1}, ${mx} ${y2}, ${x2} ${y2}`,class:'edge'+(flow?' flow':'')}));
      }
      for(const n of nodes){
        const g=mk('g',{class:'node '+n.status});
        g.appendChild(mk('rect',{x:n.x,y:n.y,width:NW,height:NH,rx:11,ry:11}));
        g.appendChild(mk('text',{class:'lab',x:n.x+13,y:n.y+22},n.label));
        g.appendChild(mk('text',{class:'sub',x:n.x+13,y:n.y+39},n.sub||''));
        nG.appendChild(g);
      }
    }
    function renderList(el, items, kind){
      el.innerHTML = items.map(it=>{
        if(kind==='wf') return `<div class="wf"><i class="dot st-${it.status}"></i><span class="nm">${esc(it.name)}</span><span class="ph">${esc(it.phase||'')}</span></div>`;
        return `<div class="item"><div class="top"><i class="dot st-${it.status}"></i><span class="id">${esc(it.id)}</span><span class="ttl">${esc(it.title)}</span><span class="pill">${esc(it.status)}</span></div>${it.note?`<div class="note">${esc(it.note)}</div>`:''}</div>`;
      }).join('');
    }
    async function tick(){
      try{
        const s = await fetch('/status.json?'+Date.now()).then(r=>r.json());
        $('headline').textContent = s.headline||'';
        $('sha').innerHTML = `<span class="tag">${esc(s.live.env)}</span> api <b>${esc(s.live.api)}</b> · ui <b>${esc(s.live.ui)}</b>`;
        $('sc-pass').textContent=s.ac.pass; $('sc-fail').textContent=s.ac.fail; $('sc-unv').textContent=s.ac.unverified;
        renderDiagram(s.architecture);
        renderArch(s.archFull);
        $('designdocs').innerHTML = (s.designDocs||[]).map(d=>`<div class="ddoc"><div class="p">${esc(d.path)}</div><div class="r">${esc(d.role)}</div></div>`).join('');
        $('d-pass').textContent=s.ac.pass; $('d-fail').textContent=s.ac.fail; $('d-unv').textContent=s.ac.unverified; $('d-tot').textContent=s.ac.total;
        renderList($('workleft'), s.workLeft);
        renderList($('workflows'), s.workflows, 'wf');
        // Design&AC tab — live workflows + in-flight + todo (mirrors sidebar, prominent)
        if($('d-inflight')) $('d-inflight').innerHTML = (s.inFlight||[]).length
          ? (s.inFlight||[]).map(f=>`<div class="iflt"><span class="ifn">${esc(f.nodeId)}</span><span class="ift">${esc(f.title)}</span>${f.note?`<div class="ifnote">${esc(f.note)}</div>`:''}</div>`).join('')
          : '<div class="note">nothing in flight</div>';
        if($('d-workflows')) renderList($('d-workflows'), s.workflows, 'wf');
        if($('d-todo')) renderList($('d-todo'), s.workLeft);
        $('events').innerHTML = (s.events||[]).map(e=>`<div class="evrow"><span class="evt">${esc(e.t)}</span><span class="evm">${esc(e.m)}</span></div>`).join('');
        $('battery').innerHTML = s.battery.map(b=>`<div class="brow"><span class="g">${esc(b.gate)}</span><span class="r ${b.result}">${esc(b.result)}</span></div>`).join('');
        $('ticker').innerHTML = s.commits.map(c=>`<span><b>${esc(c.sha)}</b> ${esc(c.title)}</span>`).join('');
        $('upd').textContent = 'updated '+new Date(s.updatedAt).toLocaleTimeString();
      }catch(e){ $('upd').textContent='status.json unavailable — '+e.message; }
    }
    function renderArch(arch){
      if(!arch) return;
      const byId = Object.fromEntries(arch.nodes.map(n=>[n.id,n]));
      const lG=$('arch-lanes'), eG=$('arch-edges'), nG=$('arch-nodes');
      [lG,eG,nG].forEach(g=>{while(g.firstChild)g.removeChild(g.firstChild)});
      for(const L of arch.lanes){
        const g=mk('g',{class:'lane'});
        const r=mk('rect',{x:L.x,y:L.y,width:L.w,height:L.h,rx:14,ry:14,stroke:L.color}); r.style.strokeOpacity='.45';
        g.appendChild(r);
        g.appendChild(mk('text',{class:'ll',x:L.x+14,y:L.y+18,fill:L.color},L.label));
        lG.appendChild(g);
      }
      for(const [a,b,lab] of arch.edges){
        const A=byId[a],B=byId[b]; if(!A||!B) continue;
        const ax=A.x+A.w/2, ay=A.y+A.h/2, bx=B.x+B.w/2, by=B.y+B.h/2;
        const y1 = ay < by ? A.y+A.h : A.y;
        const y2 = ay < by ? B.y : B.y+B.h;
        const my=(y1+y2)/2;
        const hot=(A.status==='live'||A.status==='building')&&(B.status==='live'||B.status==='building');
        const d = Math.abs(ax-bx)<6 ? `M ${ax} ${y1} L ${bx} ${y2}` : `M ${ax} ${y1} L ${ax} ${my} L ${bx} ${my} L ${bx} ${y2}`;
        eG.appendChild(mk('path',{d,class:'aedge'+(hot?' hot':''),'marker-end':'url(#arr)'}));
        if(lab) eG.appendChild(mk('text',{class:'elabel',x:(ax+bx)/2+5,y:my-3},lab));
      }
      for(const n of arch.nodes){
        const g=mk('g',{class:'anode '+n.status});
        g.appendChild(mk('rect',{x:n.x,y:n.y,width:n.w,height:n.h,rx:9,ry:9}));
        g.appendChild(mk('text',{class:'al',x:n.x+11,y:n.y+(n.sub?19:n.h/2+4)},n.label));
        if(n.sub) g.appendChild(mk('text',{class:'as',x:n.x+11,y:n.y+33},n.sub));
        nG.appendChild(g);
      }
    }
    document.querySelectorAll('.tab').forEach(t=>{
      t.addEventListener('click',()=>{
        document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
        t.classList.add('active');
        const tab=t.dataset.tab;
        $('view-flow').style.display = tab==='flow'?'':'none';
        $('view-arch').style.display = tab==='arch'?'':'none';
        $('view-design').style.display = tab==='design'?'':'none';
      });
    });
    tick(); setInterval(tick, 3000);
  </script>
</body>
</html>
